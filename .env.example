# SchoolInfo Environment Variables Configuration
# Copy this file to '.env' and populate the actual secrets.
# Do NOT commit the '.env' file to Git.

# === Database ===
POSTGRES_PASSWORD=YOUR_DB_PASSWORD_HERE

# === Security (JWT) ===
# Key must be a long cryptographically secure string (at least 256-bit / 32 bytes)
JWT_KEY=YOUR_JWT_SECRET_KEY_HERE

# === Artificial Intelligence ===
GEMINI_API_KEY=YOUR_GEMINI_API_KEY_HERE
