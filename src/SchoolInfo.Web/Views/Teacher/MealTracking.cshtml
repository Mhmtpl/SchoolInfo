@using SchoolInfo.Web.Models
@model List<StudentDetailedMealsResponse>
@{
    var classroom = ViewBag.Classroom as ClassroomDto;
    ViewData["Title"] = $"{classroom?.Name} Yemek Takibi";
}

<div class="teacher-workspace">
    <!-- Üst Başlık ve Yönlendirme -->
    <div style="display: flex; justify-content: space-between; align-items: center; border-bottom: 1px solid var(--border-color); padding-bottom: 1.5rem; margin-bottom: 2rem; flex-wrap: wrap; gap: 1rem;">
        <div>
            <a asp-action="ClassroomDetails" asp-route-id="@classroom?.Id" style="font-size: 0.85rem; color: var(--text-muted); display: inline-flex; align-items: center; gap: 0.25rem; margin-bottom: 0.5rem; text-decoration: none; font-weight: 500; transition: color 0.2s;" onmouseover="this.style.color='var(--accent-blue)'" onmouseout="this.style.color='var(--text-muted)'">
                &larr; Sınıf Defterine Geri Dön
            </a>
            <h1 style="font-size: 2.2rem; background: linear-gradient(135deg, #1e3c72 0%, #2a5298 100%); -webkit-background-clip: text; -webkit-text-fill-color: transparent; font-weight: 800;">
                @classroom?.Name Yemek Takibi 🍳🍲🧁
            </h1>
            <p style="color: var(--text-secondary); font-size: 0.95rem; margin-top: 0.25rem;">
                Bugün: <strong>@DateTime.UtcNow.ToLocalTime().ToString("dd MMMM yyyy")</strong> | Öğrencilerin günlük beslenme durumlarını buradan detaylıca yönetin.
            </p>
        </div>
        <div style="display: flex; gap: 0.75rem;">
            <button type="button" onclick="openWeeklyMealPlanModal()" style="padding: 0.75rem 1.5rem; font-size: 0.9rem; font-weight: 700; border-radius: 12px; border: 1px solid var(--border-color); background: rgba(255,255,255,0.8); color: var(--text-primary); display: inline-flex; align-items: center; gap: 0.5rem; cursor: pointer; box-shadow: 0 2px 8px rgba(0,0,0,0.05); transition: transform 0.2s, background 0.2s;" onmouseover="this.style.transform='translateY(-1px)'; this.style.background='rgba(240,242,245,0.9)'" onmouseout="this.style.transform='none'; this.style.background='rgba(255,255,255,0.8)'">
                Haftalık Şablonu Düzenle 📅
            </button>
            <button type="button" onclick="openMealPlanModal()" style="padding: 0.75rem 1.5rem; font-size: 0.9rem; font-weight: 700; border-radius: 12px; border: none; background: linear-gradient(135deg, #2a5298 0%, #1e3c72 100%); color: white; display: inline-flex; align-items: center; gap: 0.5rem; cursor: pointer; box-shadow: 0 4px 15px rgba(30, 60, 114, 0.25); transition: transform 0.2s, box-shadow 0.2s;" onmouseover="this.style.transform='translateY(-1px)'; this.style.boxShadow='0 6px 20px rgba(30, 60, 114, 0.35)'" onmouseout="this.style.transform='none'; this.style.boxShadow='0 4px 15px rgba(30, 60, 114, 0.25)'">
                Planlanan Menüyü Düzenle 📝
            </button>
        </div>
    </div>

    @if (ViewBag.ErrorMessage != null)
    {
        <div class="error-summary" style="margin-bottom: 2rem; padding: 1rem; border-radius: 12px; background: rgba(239, 68, 68, 0.1); border: 1px solid rgba(239, 68, 68, 0.2); color: #ef4444;">
            @ViewBag.ErrorMessage
        </div>
    }

    <!-- DETAYLI YEMEK GRİDİ -->
    <div class="glass-card" style="padding: 1.5rem; border-radius: 20px; border: 1px solid var(--border-color); background: rgba(255, 255, 255, 0.45); backdrop-filter: blur(20px); box-shadow: 0 10px 30px rgba(0,0,0,0.03);">
        <div class="section-card-header" style="margin-bottom: 1.5rem; display: flex; justify-content: space-between; align-items: center;">
            <div>
                <h2 style="font-size: 1.4rem; color: var(--text-primary); font-weight: 700;">Günlük Öğün Çizelgesi</h2>
                <span style="font-size: 0.85rem; color: var(--text-muted);">Öğrencilerin kahvaltı, öğle yemeği ve ikindi kahvaltısı tüketim durumlarını tek ekrandan güncelleyin.</span>
            </div>
        </div>

        @{
            var firstStudent = Model.FirstOrDefault();
            var bMeal = firstStudent?.Meals?.FirstOrDefault(m => m.MealName.Contains("Kahvaltı", StringComparison.OrdinalIgnoreCase) && !m.MealName.Contains("İkindi", StringComparison.OrdinalIgnoreCase));
            var lMeal = firstStudent?.Meals?.FirstOrDefault(m => m.MealName.Contains("Öğle", StringComparison.OrdinalIgnoreCase));
            var sMeal = firstStudent?.Meals?.FirstOrDefault(m => m.MealName.Contains("İkindi", StringComparison.OrdinalIgnoreCase));

            var bMenu = bMeal?.FoodContent;
            var lMenu = lMeal?.FoodContent;
            var sMenu = sMeal?.FoodContent;
        }
        <div class="grid-table-container" style="overflow-x: auto; border-radius: 12px; border: 1px solid var(--border-color);">
            <table class="grid-table" style="width: 100%; border-collapse: collapse; text-align: left;">
                <thead>
                    <tr style="background: rgba(240, 242, 245, 0.6); border-bottom: 2px solid var(--border-color);">
                        <th style="padding: 1.2rem 1rem; width: 22%; font-weight: 700; color: var(--text-primary); vertical-align: middle;">Öğrenci</th>
                        <th style="padding: 1.2rem 1rem; width: 26%; font-weight: 700; color: var(--text-primary); text-align: center; vertical-align: middle;">
                            <div>🍳 Kahvaltı</div>
                            <span id="header-menu-breakfast" style="font-size: 0.75rem; font-weight: 500; color: #78350f; display: @(string.IsNullOrEmpty(bMenu) ? "none" : "block"); margin-top: 0.25rem; font-style: italic; background: rgba(251, 191, 36, 0.1); padding: 0.2rem; border-radius: 4px;">@bMenu</span>
                        </th>
                        <th style="padding: 1.2rem 1rem; width: 26%; font-weight: 700; color: var(--text-primary); text-align: center; vertical-align: middle;">
                            <div>🍲 Öğle Yemeği</div>
                            <span id="header-menu-lunch" style="font-size: 0.75rem; font-weight: 500; color: #1e3a8a; display: @(string.IsNullOrEmpty(lMenu) ? "none" : "block"); margin-top: 0.25rem; font-style: italic; background: rgba(59, 130, 246, 0.1); padding: 0.2rem; border-radius: 4px;">@lMenu</span>
                        </th>
                        <th style="padding: 1.2rem 1rem; width: 26%; font-weight: 700; color: var(--text-primary); text-align: center; vertical-align: middle;">
                            <div>🧁 İkindi Kahvaltısı</div>
                            <span id="header-menu-snack" style="font-size: 0.75rem; font-weight: 500; color: #065f46; display: @(string.IsNullOrEmpty(sMenu) ? "none" : "block"); margin-top: 0.25rem; font-style: italic; background: rgba(16, 185, 129, 0.1); padding: 0.2rem; border-radius: 4px;">@sMenu</span>
                        </th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var student in Model)
                    {
                        var breakfast = student.Meals.FirstOrDefault(m => m.MealName.Contains("Kahvaltı", StringComparison.OrdinalIgnoreCase) && !m.MealName.Contains("İkindi", StringComparison.OrdinalIgnoreCase));
                        var lunch = student.Meals.FirstOrDefault(m => m.MealName.Contains("Öğle", StringComparison.OrdinalIgnoreCase));
                        var snack = student.Meals.FirstOrDefault(m => m.MealName.Contains("İkindi", StringComparison.OrdinalIgnoreCase));
                        
                        <tr style="border-bottom: 1px solid var(--border-color); transition: background 0.2s;" onmouseover="this.style.background='rgba(240, 242, 245, 0.2)'" onmouseout="this.style.background='none'">
                            <td style="padding: 1.2rem 1rem;">
                                <div class="student-info" style="font-weight: 600; color: var(--text-primary); font-size: 1rem;">
                                    @student.FirstName @student.LastName
                                </div>
                                <span style="font-size: 0.75rem; color: var(--text-muted); display: block; margin-top: 0.2rem;">
                                    Bugün 3 öğün tanımlı
                                </span>
                            </td>
                            
                            <!-- KAHVALTI CELL -->
                            <td style="padding: 1rem; vertical-align: top;">
                                @if (breakfast != null)
                                {
                                    <div class="meal-cell-container" style="background: rgba(254, 243, 199, 0.4); border: 1px solid rgba(251, 191, 36, 0.2); padding: 0.8rem; border-radius: 12px; display: flex; flex-direction: column; gap: 0.5rem;">
                                        <select id="meal-status-@student.StudentId-@breakfast.MealRecordId" class="state-select" style="width: 100%; padding: 0.4rem; border-radius: 8px; border: 1px solid rgba(0,0,0,0.1); font-size: 0.85rem;">
                                            <option value="3" selected="@(breakfast.StatusType == 3)">Hepsini Yedi</option>
                                            <option value="2" selected="@(breakfast.StatusType == 2)">Yarısını Yedi</option>
                                            <option value="1" selected="@(breakfast.StatusType == 1)">Az Yedi</option>
                                            <option value="0" selected="@(breakfast.StatusType == 0)">Hiç Yemedi</option>
                                        </select>
                                        <input type="text" id="meal-note-@student.StudentId-@breakfast.MealRecordId" class="note-input" value="@breakfast.StatusDescription" placeholder="Not ekleyin..." style="width: 100%; padding: 0.4rem; border-radius: 8px; border: 1px solid rgba(0,0,0,0.08); font-size: 0.8rem;" />
                                        <button type="button" onclick="saveIndividualMeal('@student.StudentId', '@breakfast.MealRecordId', 'Kahvaltı')" id="btn-save-@student.StudentId-@breakfast.MealRecordId" class="save-row-btn" style="width: 100%; padding: 0.4rem; font-size: 0.8rem; margin-top: 0.2rem; border-radius: 8px; border: none; background: #fbbf24; color: #78350f; font-weight: 600; cursor: pointer; transition: opacity 0.2s;">
                                            Kaydet
                                        </button>
                                    </div>
                                }
                                else
                                {
                                    <div style="text-align: center; color: var(--text-muted); font-size: 0.85rem; padding: 1rem;">Öğün tanımlanmamış</div>
                                }
                            </td>

                            <!-- ÖĞLE YEMEĞİ CELL -->
                            <td style="padding: 1rem; vertical-align: top;">
                                @if (lunch != null)
                                {
                                    <div class="meal-cell-container" style="background: rgba(219, 234, 254, 0.4); border: 1px solid rgba(59, 130, 246, 0.2); padding: 0.8rem; border-radius: 12px; display: flex; flex-direction: column; gap: 0.5rem;">
                                        <select id="meal-status-@student.StudentId-@lunch.MealRecordId" class="state-select" style="width: 100%; padding: 0.4rem; border-radius: 8px; border: 1px solid rgba(0,0,0,0.1); font-size: 0.85rem;">
                                            <option value="3" selected="@(lunch.StatusType == 3)">Hepsini Yedi</option>
                                            <option value="2" selected="@(lunch.StatusType == 2)">Yarısını Yedi</option>
                                            <option value="1" selected="@(lunch.StatusType == 1)">Az Yedi</option>
                                            <option value="0" selected="@(lunch.StatusType == 0)">Hiç Yemedi</option>
                                        </select>
                                        <input type="text" id="meal-note-@student.StudentId-@lunch.MealRecordId" class="note-input" value="@lunch.StatusDescription" placeholder="Not ekleyin..." style="width: 100%; padding: 0.4rem; border-radius: 8px; border: 1px solid rgba(0,0,0,0.08); font-size: 0.8rem;" />
                                        <button type="button" onclick="saveIndividualMeal('@student.StudentId', '@lunch.MealRecordId', 'Öğle Yemeği')" id="btn-save-@student.StudentId-@lunch.MealRecordId" class="save-row-btn" style="width: 100%; padding: 0.4rem; font-size: 0.8rem; margin-top: 0.2rem; border-radius: 8px; border: none; background: #3b82f6; color: white; font-weight: 600; cursor: pointer; transition: opacity 0.2s;">
                                            Kaydet
                                        </button>
                                    </div>
                                }
                                else
                                {
                                    <div style="text-align: center; color: var(--text-muted); font-size: 0.85rem; padding: 1rem;">Öğün tanımlanmamış</div>
                                }
                            </td>

                            <!-- İKİNDİ CELL -->
                            <td style="padding: 1rem; vertical-align: top;">
                                @if (snack != null)
                                {
                                    <div class="meal-cell-container" style="background: rgba(243, 244, 246, 0.8); border: 1px solid rgba(156, 163, 175, 0.2); padding: 0.8rem; border-radius: 12px; display: flex; flex-direction: column; gap: 0.5rem;">
                                        <select id="meal-status-@student.StudentId-@snack.MealRecordId" class="state-select" style="width: 100%; padding: 0.4rem; border-radius: 8px; border: 1px solid rgba(0,0,0,0.1); font-size: 0.85rem;">
                                            <option value="3" selected="@(snack.StatusType == 3)">Hepsini Yedi</option>
                                            <option value="2" selected="@(snack.StatusType == 2)">Yarısını Yedi</option>
                                            <option value="1" selected="@(snack.StatusType == 1)">Az Yedi</option>
                                            <option value="0" selected="@(snack.StatusType == 0)">Hiç Yemedi</option>
                                        </select>
                                        <input type="text" id="meal-note-@student.StudentId-@snack.MealRecordId" class="note-input" value="@snack.StatusDescription" placeholder="Not ekleyin..." style="width: 100%; padding: 0.4rem; border-radius: 8px; border: 1px solid rgba(0,0,0,0.08); font-size: 0.8rem;" />
                                        <button type="button" onclick="saveIndividualMeal('@student.StudentId', '@snack.MealRecordId', 'İkindi Kahvaltısı')" id="btn-save-@student.StudentId-@snack.MealRecordId" class="save-row-btn" style="width: 100%; padding: 0.4rem; font-size: 0.8rem; margin-top: 0.2rem; border-radius: 8px; border: none; background: #10b981; color: white; font-weight: 600; cursor: pointer; transition: opacity 0.2s;">
                                            Kaydet
                                        </button>
                                    </div>
                                }
                                else
                                {
                                    <div style="text-align: center; color: var(--text-muted); font-size: 0.85rem; padding: 1rem;">Öğün tanımlanmamış</div>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
    </div>

    <!-- DİNAMİK MENÜ PLANLAMA MODALI -->
    <div id="mealPlanModal" style="display: none; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.5); backdrop-filter: blur(8px); z-index: 1000; align-items: center; justify-content: center;">
        <div class="glass-card" style="width: 90%; max-width: 650px; background: rgba(255, 255, 255, 0.95); border-radius: 24px; border: 1px solid rgba(255,255,255,0.4); box-shadow: 0 20px 50px rgba(0,0,0,0.15); padding: 2rem; position: relative; max-height: 90vh; overflow-y: auto;">
            
            <button type="button" onclick="closeMealPlanModal()" style="position: absolute; top: 1.2rem; right: 1.2rem; background: none; border: none; font-size: 1.5rem; cursor: pointer; color: var(--text-muted); transition: color 0.2s;" onmouseover="this.style.color='var(--text-primary)'" onmouseout="this.style.color='var(--text-muted)'">&times;</button>
            
            <h2 style="font-size: 1.6rem; font-weight: 800; background: linear-gradient(135deg, #1e3c72 0%, #2a5298 100%); -webkit-background-clip: text; -webkit-text-fill-color: transparent; margin-bottom: 0.5rem; display: flex; align-items: center; gap: 0.5rem;">
                Planlanan Menüyü Düzenle 📝
            </h2>
            <p style="color: var(--text-secondary); font-size: 0.85rem; margin-bottom: 1.5rem;">Sınıfın bugünkü tüm yemek planlarını buradan güncelleyin.</p>
            
            <form id="mealPlanForm" style="display: flex; flex-direction: column; gap: 1.5rem;">
                
                <!-- KAHVALTI BÖLÜMÜ -->
                <div style="background: rgba(254, 243, 199, 0.35); border: 1px solid rgba(251, 191, 36, 0.2); padding: 1.2rem; border-radius: 16px;">
                    <h3 style="font-size: 1rem; font-weight: 700; color: #78350f; margin-bottom: 0.8rem; display: flex; align-items: center; gap: 0.4rem;">🍳 Kahvaltı Planı</h3>
                    <div style="display: grid; grid-template-columns: 2fr 1fr 1fr 1fr; gap: 0.75rem;">
                        <div>
                            <label style="font-size: 0.75rem; font-weight: 600; color: #78350f; display: block; margin-bottom: 0.25rem;">Menü İçeriği</label>
                            <input type="text" id="modal-breakfast-food" value="@bMeal?.FoodContent" placeholder="Yumurta, peynir vb..." style="width:100%; padding: 0.5rem; border-radius: 8px; border: 1px solid rgba(0,0,0,0.1); font-size: 0.85rem;" />
                        </div>
                        <div>
                            <label style="font-size: 0.75rem; font-weight: 600; color: #78350f; display: block; margin-bottom: 0.25rem;">Kalori (kcal)</label>
                            <input type="number" id="modal-breakfast-cal" value="@bMeal?.PlannedCalories" placeholder="220" style="width:100%; padding: 0.5rem; border-radius: 8px; border: 1px solid rgba(0,0,0,0.1); font-size: 0.85rem;" />
                        </div>
                        <div>
                            <label style="font-size: 0.75rem; font-weight: 600; color: #78350f; display: block; margin-bottom: 0.25rem;">Protein (g)</label>
                            <input type="number" step="0.1" id="modal-breakfast-prot" value="@bMeal?.ProteinGrams" placeholder="10" style="width:100%; padding: 0.5rem; border-radius: 8px; border: 1px solid rgba(0,0,0,0.1); font-size: 0.85rem;" />
                        </div>
                        <div>
                            <label style="font-size: 0.75rem; font-weight: 600; color: #78350f; display: block; margin-bottom: 0.25rem;">Karb (g)</label>
                            <input type="number" step="0.1" id="modal-breakfast-carb" value="@bMeal?.CarbsGrams" placeholder="15" style="width:100%; padding: 0.5rem; border-radius: 8px; border: 1px solid rgba(0,0,0,0.1); font-size: 0.85rem;" />
                        </div>
                    </div>
                </div>

                <!-- ÖĞLE YEMEĞİ BÖLÜMÜ -->
                <div style="background: rgba(219, 234, 254, 0.35); border: 1px solid rgba(59, 130, 246, 0.2); padding: 1.2rem; border-radius: 16px;">
                    <h3 style="font-size: 1rem; font-weight: 700; color: #1e3a8a; margin-bottom: 0.8rem; display: flex; align-items: center; gap: 0.4rem;">🍲 Öğle Yemeği Planı</h3>
                    <div style="display: grid; grid-template-columns: 2fr 1fr 1fr 1fr; gap: 0.75rem;">
                        <div>
                            <label style="font-size: 0.75rem; font-weight: 600; color: #1e3a8a; display: block; margin-bottom: 0.25rem;">Menü İçeriği</label>
                            <input type="text" id="modal-lunch-food" value="@lMeal?.FoodContent" placeholder="Çorba, köfte, pilav..." style="width:100%; padding: 0.5rem; border-radius: 8px; border: 1px solid rgba(0,0,0,0.1); font-size: 0.85rem;" />
                        </div>
                        <div>
                            <label style="font-size: 0.75rem; font-weight: 600; color: #1e3a8a; display: block; margin-bottom: 0.25rem;">Kalori (kcal)</label>
                            <input type="number" id="modal-lunch-cal" value="@lMeal?.PlannedCalories" placeholder="480" style="width:100%; padding: 0.5rem; border-radius: 8px; border: 1px solid rgba(0,0,0,0.1); font-size: 0.85rem;" />
                        </div>
                        <div>
                            <label style="font-size: 0.75rem; font-weight: 600; color: #1e3a8a; display: block; margin-bottom: 0.25rem;">Protein (g)</label>
                            <input type="number" step="0.1" id="modal-lunch-prot" value="@lMeal?.ProteinGrams" placeholder="22" style="width:100%; padding: 0.5rem; border-radius: 8px; border: 1px solid rgba(0,0,0,0.1); font-size: 0.85rem;" />
                        </div>
                        <div>
                            <label style="font-size: 0.75rem; font-weight: 600; color: #1e3a8a; display: block; margin-bottom: 0.25rem;">Karb (g)</label>
                            <input type="number" step="0.1" id="modal-lunch-carb" value="@lMeal?.CarbsGrams" placeholder="50" style="width:100%; padding: 0.5rem; border-radius: 8px; border: 1px solid rgba(0,0,0,0.1); font-size: 0.85rem;" />
                        </div>
                    </div>
                </div>

                <!-- İKİNDİ KAHVALTISI BÖLÜMÜ -->
                <div style="background: rgba(243, 244, 246, 0.65); border: 1px solid rgba(156, 163, 175, 0.2); padding: 1.2rem; border-radius: 16px;">
                    <h3 style="font-size: 1rem; font-weight: 700; color: #374151; margin-bottom: 0.8rem; display: flex; align-items: center; gap: 0.4rem;">🧁 İkindi Kahvaltısı Planı</h3>
                    <div style="display: grid; grid-template-columns: 2fr 1fr 1fr 1fr; gap: 0.75rem;">
                        <div>
                            <label style="font-size: 0.75rem; font-weight: 600; color: #374151; display: block; margin-bottom: 0.25rem;">Menü İçeriği</label>
                            <input type="text" id="modal-snack-food" value="@sMeal?.FoodContent" placeholder="Kek, süt, meyve..." style="width:100%; padding: 0.5rem; border-radius: 8px; border: 1px solid rgba(0,0,0,0.1); font-size: 0.85rem;" />
                        </div>
                        <div>
                            <label style="font-size: 0.75rem; font-weight: 600; color: #374151; display: block; margin-bottom: 0.25rem;">Kalori (kcal)</label>
                            <input type="number" id="modal-snack-cal" value="@sMeal?.PlannedCalories" placeholder="190" style="width:100%; padding: 0.5rem; border-radius: 8px; border: 1px solid rgba(0,0,0,0.1); font-size: 0.85rem;" />
                        </div>
                        <div>
                            <label style="font-size: 0.75rem; font-weight: 600; color: #374151; display: block; margin-bottom: 0.25rem;">Protein (g)</label>
                            <input type="number" step="0.1" id="modal-snack-prot" value="@sMeal?.ProteinGrams" placeholder="6" style="width:100%; padding: 0.5rem; border-radius: 8px; border: 1px solid rgba(0,0,0,0.1); font-size: 0.85rem;" />
                        </div>
                        <div>
                            <label style="font-size: 0.75rem; font-weight: 600; color: #374151; display: block; margin-bottom: 0.25rem;">Karb (g)</label>
                            <input type="number" step="0.1" id="modal-snack-carb" value="@sMeal?.CarbsGrams" placeholder="28" style="width:100%; padding: 0.5rem; border-radius: 8px; border: 1px solid rgba(0,0,0,0.1); font-size: 0.85rem;" />
                        </div>
                    </div>
                </div>

                <!-- AKSİYON BUTONLARI -->
                <div style="display: flex; justify-content: flex-end; gap: 0.75rem; margin-top: 1rem;">
                    <button type="button" onclick="closeMealPlanModal()" style="padding: 0.6rem 1.2rem; border-radius: 10px; border: 1px solid var(--border-color); background: white; color: var(--text-secondary); font-weight: 600; cursor: pointer; transition: background 0.2s;" onmouseover="this.style.background='#f3f4f6'" onmouseout="this.style.background='white'">İptal</button>
                    <button type="button" onclick="saveClassroomMealPlan()" id="btn-save-meal-plan" style="padding: 0.6rem 1.5rem; border-radius: 10px; border: none; background: linear-gradient(135deg, #1e3c72 0%, #2a5298 100%); color: white; font-weight: 700; cursor: pointer; box-shadow: 0 4px 15px rgba(30, 60, 114, 0.2); transition: opacity 0.2s;">Menüyü Kaydet ve Uygula</button>
                </div>

            </form>
        </div>
    </div>
</div>

<!-- HAFTALIK ŞABLON MODALI -->
<div id="weeklyMealPlanModal" style="display: none; position: fixed; inset: 0; background: rgba(0, 0, 0, 0.4); backdrop-filter: blur(8px); z-index: 1000; justify-content: center; align-items: center; padding: 1.5rem;">
    <div style="background: rgba(255, 255, 255, 0.85); backdrop-filter: blur(25px); border: 1px solid rgba(255, 255, 255, 0.4); border-radius: 24px; box-shadow: 0 20px 50px rgba(0,0,0,0.15); width: 100%; max-width: 650px; max-height: 90vh; overflow-y: auto; display: flex; flex-direction: column; animation: modalFadeIn 0.3s ease-out;">
        <!-- Modal Başlığı -->
        <div style="padding: 1.5rem 2rem; border-bottom: 1px solid rgba(0,0,0,0.08); display: flex; justify-content: space-between; align-items: center; background: linear-gradient(135deg, rgba(30, 60, 114, 0.03) 0%, rgba(42, 82, 152, 0.03) 100%);">
            <div>
                <h3 style="font-size: 1.3rem; font-weight: 800; color: #1e3c72; margin: 0;">Haftalık Yemek Şablonu Düzenle 📅</h3>
                <p style="font-size: 0.8rem; color: #6b7280; margin: 0.25rem 0 0 0;">Bu sınıfa ait öğrencilerin günlük öğünleri bu şablondan otomatik olarak beslenecektir.</p>
            </div>
            <button type="button" onclick="closeWeeklyMealPlanModal()" style="border: none; background: none; font-size: 1.5rem; color: #9ca3af; cursor: pointer; transition: color 0.2s;" onmouseover="this.style.color='#374151'" onmouseout="this.style.color='#9ca3af'">&times;</button>
        </div>

        <!-- Modal İçeriği -->
        <div style="padding: 1.5rem 2rem; flex: 1; display: flex; flex-direction: column; gap: 1rem;">
            <!-- Gün Seçim Butonları -->
            <div style="display: flex; gap: 0.35rem; justify-content: space-between; background: rgba(0,0,0,0.03); padding: 0.25rem; border-radius: 12px; border: 1px solid rgba(0,0,0,0.04);">
                <button type="button" onclick="selectWeeklyDay(1)" id="btn-day-1" style="flex: 1; padding: 0.6rem 0.25rem; border: none; border-radius: 9px; font-size: 0.85rem; font-weight: 700; cursor: pointer; background: transparent; color: #4b5563; transition: all 0.2s;">Pazartesi</button>
                <button type="button" onclick="selectWeeklyDay(2)" id="btn-day-2" style="flex: 1; padding: 0.6rem 0.25rem; border: none; border-radius: 9px; font-size: 0.85rem; font-weight: 700; cursor: pointer; background: transparent; color: #4b5563; transition: all 0.2s;">Salı</button>
                <button type="button" onclick="selectWeeklyDay(3)" id="btn-day-3" style="flex: 1; padding: 0.6rem 0.25rem; border: none; border-radius: 9px; font-size: 0.85rem; font-weight: 700; cursor: pointer; background: transparent; color: #4b5563; transition: all 0.2s;">Çarşamba</button>
                <button type="button" onclick="selectWeeklyDay(4)" id="btn-day-4" style="flex: 1; padding: 0.6rem 0.25rem; border: none; border-radius: 9px; font-size: 0.85rem; font-weight: 700; cursor: pointer; background: transparent; color: #4b5563; transition: all 0.2s;">Perşembe</button>
                <button type="button" onclick="selectWeeklyDay(5)" id="btn-day-5" style="flex: 1; padding: 0.6rem 0.25rem; border: none; border-radius: 9px; font-size: 0.85rem; font-weight: 700; cursor: pointer; background: transparent; color: #4b5563; transition: all 0.2s;">Cuma</button>
            </div>

            <div style="max-height: 50vh; overflow-y: auto; padding-right: 0.5rem; display: flex; flex-direction: column; gap: 1rem;">
                <!-- KAHVALTI -->
                <div style="background: rgba(251, 191, 36, 0.05); border: 1px solid rgba(251, 191, 36, 0.15); border-radius: 16px; padding: 1rem; display: flex; flex-direction: column; gap: 0.75rem;">
                    <div style="display: flex; align-items: center; gap: 0.5rem; border-bottom: 1px solid rgba(251, 191, 36, 0.2); padding-bottom: 0.5rem;">
                        <span style="font-size: 1.1rem;">🍳</span>
                        <strong style="color: #78350f; font-size: 0.95rem;">Kahvaltı Şablonu</strong>
                    </div>
                    <div style="display: grid; grid-template-columns: 2fr 1fr 1fr 1fr; gap: 0.5rem; align-items: end;">
                        <div>
                            <label style="font-size: 0.75rem; font-weight: 600; color: #78350f; display: block; margin-bottom: 0.25rem;">Menü İçeriği</label>
                            <input type="text" id="weekly-breakfast-food" placeholder="Yumurtalı ekmek, peynir, ıhlamur..." style="width:100%; padding: 0.5rem; border-radius: 8px; border: 1px solid rgba(251, 191, 36, 0.3); font-size: 0.85rem; background: white;" />
                        </div>
                        <div>
                            <label style="font-size: 0.75rem; font-weight: 600; color: #78350f; display: block; margin-bottom: 0.25rem;">Kalori (kcal)</label>
                            <input type="number" id="weekly-breakfast-cal" placeholder="210" style="width:100%; padding: 0.5rem; border-radius: 8px; border: 1px solid rgba(251, 191, 36, 0.3); font-size: 0.85rem; background: white;" />
                        </div>
                        <div>
                            <label style="font-size: 0.75rem; font-weight: 600; color: #78350f; display: block; margin-bottom: 0.25rem;">Prot (g)</label>
                            <input type="number" step="0.1" id="weekly-breakfast-prot" placeholder="9" style="width:100%; padding: 0.5rem; border-radius: 8px; border: 1px solid rgba(251, 191, 36, 0.3); font-size: 0.85rem; background: white;" />
                        </div>
                        <div>
                            <label style="font-size: 0.75rem; font-weight: 600; color: #78350f; display: block; margin-bottom: 0.25rem;">Karb (g)</label>
                            <input type="number" step="0.1" id="weekly-breakfast-carb" placeholder="18" style="width:100%; padding: 0.5rem; border-radius: 8px; border: 1px solid rgba(251, 191, 36, 0.3); font-size: 0.85rem; background: white;" />
                        </div>
                    </div>
                </div>

                <!-- ÖĞLE YEMEĞİ -->
                <div style="background: rgba(59, 130, 246, 0.05); border: 1px solid rgba(59, 130, 246, 0.15); border-radius: 16px; padding: 1rem; display: flex; flex-direction: column; gap: 0.75rem;">
                    <div style="display: flex; align-items: center; gap: 0.5rem; border-bottom: 1px solid rgba(59, 130, 246, 0.2); padding-bottom: 0.5rem;">
                        <span style="font-size: 1.1rem;">🍲</span>
                        <strong style="color: #1e3c72; font-size: 0.95rem;">Öğle Yemeği Şablonu</strong>
                    </div>
                    <div style="display: grid; grid-template-columns: 2fr 1fr 1fr 1fr; gap: 0.5rem; align-items: end;">
                        <div>
                            <label style="font-size: 0.75rem; font-weight: 600; color: #1e3c72; display: block; margin-bottom: 0.25rem;">Menü İçeriği</label>
                            <input type="text" id="weekly-lunch-food" placeholder="Çorba, tavuk, pilav..." style="width:100%; padding: 0.5rem; border-radius: 8px; border: 1px solid rgba(59, 130, 246, 0.3); font-size: 0.85rem; background: white;" />
                        </div>
                        <div>
                            <label style="font-size: 0.75rem; font-weight: 600; color: #1e3c72; display: block; margin-bottom: 0.25rem;">Kalori (kcal)</label>
                            <input type="number" id="weekly-lunch-cal" placeholder="520" style="width:100%; padding: 0.5rem; border-radius: 8px; border: 1px solid rgba(59, 130, 246, 0.3); font-size: 0.85rem; background: white;" />
                        </div>
                        <div>
                            <label style="font-size: 0.75rem; font-weight: 600; color: #1e3c72; display: block; margin-bottom: 0.25rem;">Prot (g)</label>
                            <input type="number" step="0.1" id="weekly-lunch-prot" placeholder="28" style="width:100%; padding: 0.5rem; border-radius: 8px; border: 1px solid rgba(59, 130, 246, 0.3); font-size: 0.85rem; background: white;" />
                        </div>
                        <div>
                            <label style="font-size: 0.75rem; font-weight: 600; color: #1e3c72; display: block; margin-bottom: 0.25rem;">Karb (g)</label>
                            <input type="number" step="0.1" id="weekly-lunch-carb" placeholder="55" style="width:100%; padding: 0.5rem; border-radius: 8px; border: 1px solid rgba(59, 130, 246, 0.3); font-size: 0.85rem; background: white;" />
                        </div>
                    </div>
                </div>

                <!-- İKİNDİ KAHVALTISI -->
                <div style="background: rgba(16, 185, 129, 0.05); border: 1px solid rgba(16, 185, 129, 0.15); border-radius: 16px; padding: 1rem; display: flex; flex-direction: column; gap: 0.75rem;">
                    <div style="display: flex; align-items: center; gap: 0.5rem; border-bottom: 1px solid rgba(16, 185, 129, 0.2); padding-bottom: 0.5rem;">
                        <span style="font-size: 1.1rem;">🧁</span>
                        <strong style="color: #065f46; font-size: 0.95rem;">İkindi Kahvaltısı Şablonu</strong>
                    </div>
                    <div style="display: grid; grid-template-columns: 2fr 1fr 1fr 1fr; gap: 0.5rem; align-items: end;">
                        <div>
                            <label style="font-size: 0.75rem; font-weight: 600; color: #065f46; display: block; margin-bottom: 0.25rem;">Menü İçeriği</label>
                            <input type="text" id="weekly-snack-food" placeholder="Yoğurt, grissini, kek..." style="width:100%; padding: 0.5rem; border-radius: 8px; border: 1px solid rgba(16, 185, 129, 0.3); font-size: 0.85rem; background: white;" />
                        </div>
                        <div>
                            <label style="font-size: 0.75rem; font-weight: 600; color: #065f46; display: block; margin-bottom: 0.25rem;">Kalori (kcal)</label>
                            <input type="number" id="weekly-snack-cal" placeholder="180" style="width:100%; padding: 0.5rem; border-radius: 8px; border: 1px solid rgba(16, 185, 129, 0.3); font-size: 0.85rem; background: white;" />
                        </div>
                        <div>
                            <label style="font-size: 0.75rem; font-weight: 600; color: #065f46; display: block; margin-bottom: 0.25rem;">Prot (g)</label>
                            <input type="number" step="0.1" id="weekly-snack-prot" placeholder="5" style="width:100%; padding: 0.5rem; border-radius: 8px; border: 1px solid rgba(16, 185, 129, 0.3); font-size: 0.85rem; background: white;" />
                        </div>
                        <div>
                            <label style="font-size: 0.75rem; font-weight: 600; color: #065f46; display: block; margin-bottom: 0.25rem;">Karb (g)</label>
                            <input type="number" step="0.1" id="weekly-snack-carb" placeholder="25" style="width:100%; padding: 0.5rem; border-radius: 8px; border: 1px solid rgba(16, 185, 129, 0.3); font-size: 0.85rem; background: white;" />
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Modal Aksiyonları -->
        <div style="padding: 1.2rem 2rem; border-top: 1px solid rgba(0,0,0,0.08); display: flex; justify-content: flex-end; gap: 0.75rem; background: rgba(0,0,0,0.01);">
            <button type="button" onclick="closeWeeklyMealPlanModal()" style="padding: 0.6rem 1.2rem; border-radius: 10px; border: 1px solid var(--border-color); background: white; color: var(--text-secondary); font-weight: 600; cursor: pointer; transition: background 0.2s;" onmouseover="this.style.background='#f3f4f6'" onmouseout="this.style.background='white'">Vazgeç</button>
            <button type="button" onclick="saveWeeklyMealPlans()" id="btn-save-weekly-plans" style="padding: 0.6rem 1.5rem; border-radius: 10px; border: none; background: linear-gradient(135deg, #1e3c72 0%, #2a5298 100%); color: white; font-weight: 700; cursor: pointer; box-shadow: 0 4px 15px rgba(30, 60, 114, 0.2); transition: opacity 0.2s;">Haftalık Şablonu Kaydet</button>
        </div>
    </div>
</div>

<style>
    @@keyframes modalFadeIn {
        from { opacity: 0; transform: scale(0.95); }
        to { opacity: 1; transform: scale(1); }
    }
</style>

@section Scripts {
    <script>
        async function saveIndividualMeal(studentId, mealRecordId, mealName) {
            const btn = document.getElementById(`btn-save-${studentId}-${mealRecordId}`);
            const originalText = btn.innerText;
            
            btn.innerText = "Kaydediliyor...";
            btn.disabled = true;
            btn.style.opacity = "0.7";

            const status = parseInt(document.getElementById(`meal-status-${studentId}-${mealRecordId}`).value);
            const note = document.getElementById(`meal-note-${studentId}-${mealRecordId}`).value;

            try {
                const response = await fetch('/Teacher/UpdateMealRecord', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({
                        studentId: studentId,
                        mealRecordId: mealRecordId,
                        mealName: mealName,
                        statusType: status,
                        statusDescription: note
                    })
                });
                
                const data = await response.json();

                if (data.success) {
                    btn.innerText = "✓ Kaydedildi!";
                    btn.style.background = "#10b981";
                    btn.style.color = "white";
                    
                    setTimeout(() => {
                        btn.innerText = originalText;
                        // Reset background color according to meal type
                        if (mealName.includes("Kahvaltı")) {
                            btn.style.background = "#fbbf24";
                            btn.style.color = "#78350f";
                        } else if (mealName.includes("Öğle")) {
                            btn.style.background = "#3b82f6";
                            btn.style.color = "white";
                        } else {
                            btn.style.background = "#10b981";
                            btn.style.color = "white";
                        }
                        btn.disabled = false;
                        btn.style.opacity = "1";
                    }, 2000);
                } else {
                    alert("Öğün kaydedilirken bir hata oluştu: " + data.message);
                    btn.innerText = "Hata! Tekrar Dene";
                    btn.style.background = "#ef4444";
                    btn.style.color = "white";
                    btn.disabled = false;
                    btn.style.opacity = "1";
                }
            } catch (err) {
                console.error(err);
                alert("İletişim hatası oluştu!");
                btn.innerText = "Tekrar Dene";
                btn.disabled = false;
                btn.style.opacity = "1";
            }
        }

        function openMealPlanModal() {
            document.getElementById('mealPlanModal').style.display = 'flex';
        }

        function closeMealPlanModal() {
            document.getElementById('mealPlanModal').style.display = 'none';
        }

        async function saveClassroomMealPlan() {
            const btn = document.getElementById('btn-save-meal-plan');
            const originalText = btn.innerText;

            btn.innerText = "Kaydediliyor...";
            btn.disabled = true;
            btn.style.opacity = "0.7";

            const payload = {
                classroomId: '@classroom?.Id',
                meals: [
                    {
                        mealName: 'Kahvaltı',
                        plannedCalories: parseInt(document.getElementById('modal-breakfast-cal').value || 0),
                        foodContent: document.getElementById('modal-breakfast-food').value || '',
                        proteinGrams: parseFloat(document.getElementById('modal-breakfast-prot').value || 0),
                        carbsGrams: parseFloat(document.getElementById('modal-breakfast-carb').value || 0)
                    },
                    {
                        mealName: 'Öğle Yemeği',
                        plannedCalories: parseInt(document.getElementById('modal-lunch-cal').value || 0),
                        foodContent: document.getElementById('modal-lunch-food').value || '',
                        proteinGrams: parseFloat(document.getElementById('modal-lunch-prot').value || 0),
                        carbsGrams: parseFloat(document.getElementById('modal-lunch-carb').value || 0)
                    },
                    {
                        mealName: 'İkindi Kahvaltısı',
                        plannedCalories: parseInt(document.getElementById('modal-snack-cal').value || 0),
                        foodContent: document.getElementById('modal-snack-food').value || '',
                        proteinGrams: parseFloat(document.getElementById('modal-snack-prot').value || 0),
                        carbsGrams: parseFloat(document.getElementById('modal-snack-carb').value || 0)
                    }
                ]
            };

            try {
                const response = await fetch('/Teacher/UpdateClassroomMealPlan', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(payload)
                });

                const data = await response.json();

                if (data.success) {
                    btn.innerText = "✓ Kaydedildi!";
                    btn.style.background = "#10b981";

                    // Update UI titles dynamically
                    payload.meals.forEach(meal => {
                        let headerId = '';
                        if (meal.mealName.includes('Kahvaltı')) headerId = 'header-menu-breakfast';
                        else if (meal.mealName.includes('Öğle')) headerId = 'header-menu-lunch';
                        else if (meal.mealName.includes('İkindi')) headerId = 'header-menu-snack';

                        const headerSpan = document.getElementById(headerId);
                        if (headerSpan) {
                            if (meal.foodContent) {
                                headerSpan.innerText = meal.foodContent;
                                headerSpan.style.display = 'block';
                            } else {
                                headerSpan.style.display = 'none';
                            }
                        }
                    });

                    setTimeout(() => {
                        closeMealPlanModal();
                        window.location.reload();
                    }, 1000);
                } else {
                    alert("Menü kaydedilirken hata oluştu: " + data.message);
                    btn.innerText = originalText;
                    btn.disabled = false;
                    btn.style.opacity = "1";
                }
            } catch (err) {
                console.error(err);
                alert("İletişim hatası oluştu!");
                btn.innerText = originalText;
                btn.disabled = false;
                btn.style.opacity = "1";
            }
        }

        let currentSelectedWeeklyDay = -1;
        let weeklyMealPlansData = [];

        async function openWeeklyMealPlanModal() {
            try {
                const response = await fetch(`/Teacher/GetWeeklyMealPlans?classroomId=@classroom?.Id`);
                const resData = await response.json();
                if (resData.success) {
                    weeklyMealPlansData = (resData.plans || []).map(p => ({
                        id: p.id || p.Id || p.ID || '00000000-0000-0000-0000-000000000000',
                        dayOfWeek: p.dayOfWeek !== undefined ? p.dayOfWeek : p.DayOfWeek,
                        mealName: p.mealName || p.MealName || '',
                        plannedCalories: p.plannedCalories !== undefined ? p.plannedCalories : p.PlannedCalories,
                        foodContent: p.foodContent || p.FoodContent || '',
                        proteinGrams: p.proteinGrams !== undefined ? p.proteinGrams : p.ProteinGrams,
                        carbsGrams: p.carbsGrams !== undefined ? p.carbsGrams : p.CarbsGrams
                    }));
                    initializeWeeklyDataDefaults();
                    document.getElementById('weeklyMealPlanModal').style.display = 'flex';
                    selectWeeklyDay(1);
                } else {
                    alert("Şablon verileri yüklenirken hata oluştu: " + resData.message);
                }
            } catch (err) {
                console.error(err);
                alert("Veriler alınırken iletişim hatası oluştu.");
            }
        }

        function closeWeeklyMealPlanModal() {
            document.getElementById('weeklyMealPlanModal').style.display = 'none';
            currentSelectedWeeklyDay = -1;
        }

        function initializeWeeklyDataDefaults() {
            const meals = ["Kahvaltı", "Öğle Yemeği", "İkindi Kahvaltısı"];
            for (let d = 1; d <= 5; d++) {
                meals.forEach(mName => {
                    const exists = weeklyMealPlansData.some(p => p.dayOfWeek === d && p.mealName.toLowerCase() === mName.toLowerCase());
                    if (!exists) {
                        weeklyMealPlansData.push({
                            id: '00000000-0000-0000-0000-000000000000',
                            dayOfWeek: d,
                            mealName: mName,
                            plannedCalories: 0,
                            foodContent: '',
                            proteinGrams: 0,
                            carbsGrams: 0
                        });
                    }
                });
            }
        }

        function selectWeeklyDay(dayNum) {
            saveCurrentWeeklyDayInputsToData();
            currentSelectedWeeklyDay = dayNum;

            for (let i = 1; i <= 5; i++) {
                const btn = document.getElementById(`btn-day-${i}`);
                if (btn) {
                    if (i === dayNum) {
                        btn.style.background = 'linear-gradient(135deg, #1e3c72 0%, #2a5298 100%)';
                        btn.style.color = 'white';
                        btn.style.boxShadow = '0 4px 10px rgba(30, 60, 114, 0.2)';
                    } else {
                        btn.style.background = 'transparent';
                        btn.style.color = '#4b5563';
                        btn.style.boxShadow = 'none';
                    }
                }
            }

            loadWeeklyDayInputsFromData(dayNum);
        }

        function saveCurrentWeeklyDayInputsToData() {
            if (currentSelectedWeeklyDay < 1 || currentSelectedWeeklyDay > 5) return;

            const bf = weeklyMealPlansData.find(p => p.dayOfWeek === currentSelectedWeeklyDay && p.mealName.toLowerCase().includes('kahvaltı') && !p.mealName.toLowerCase().includes('ikindi'));
            const lu = weeklyMealPlansData.find(p => p.dayOfWeek === currentSelectedWeeklyDay && p.mealName.toLowerCase().includes('öğle'));
            const sn = weeklyMealPlansData.find(p => p.dayOfWeek === currentSelectedWeeklyDay && p.mealName.toLowerCase().includes('ikindi'));

            if (bf) {
                bf.foodContent = document.getElementById('weekly-breakfast-food').value || '';
                bf.plannedCalories = parseInt(document.getElementById('weekly-breakfast-cal').value) || 0;
                bf.proteinGrams = parseFloat(document.getElementById('weekly-breakfast-prot').value) || 0;
                bf.carbsGrams = parseFloat(document.getElementById('weekly-breakfast-carb').value) || 0;
            }
            if (lu) {
                lu.foodContent = document.getElementById('weekly-lunch-food').value || '';
                lu.plannedCalories = parseInt(document.getElementById('weekly-lunch-cal').value) || 0;
                lu.proteinGrams = parseFloat(document.getElementById('weekly-lunch-prot').value) || 0;
                lu.carbsGrams = parseFloat(document.getElementById('weekly-lunch-carb').value) || 0;
            }
            if (sn) {
                sn.foodContent = document.getElementById('weekly-snack-food').value || '';
                sn.plannedCalories = parseInt(document.getElementById('weekly-snack-cal').value) || 0;
                sn.proteinGrams = parseFloat(document.getElementById('weekly-snack-prot').value) || 0;
                sn.carbsGrams = parseFloat(document.getElementById('weekly-snack-carb').value) || 0;
            }
        }

        function loadWeeklyDayInputsFromData(dayNum) {
            const bf = weeklyMealPlansData.find(p => p.dayOfWeek === dayNum && p.mealName.toLowerCase().includes('kahvaltı') && !p.mealName.toLowerCase().includes('ikindi'));
            const lu = weeklyMealPlansData.find(p => p.dayOfWeek === dayNum && p.mealName.toLowerCase().includes('öğle'));
            const sn = weeklyMealPlansData.find(p => p.dayOfWeek === dayNum && p.mealName.toLowerCase().includes('ikindi'));

            document.getElementById('weekly-breakfast-food').value = bf ? bf.foodContent : '';
            document.getElementById('weekly-breakfast-cal').value = bf ? (bf.plannedCalories || '') : '';
            document.getElementById('weekly-breakfast-prot').value = bf ? (bf.proteinGrams || '') : '';
            document.getElementById('weekly-breakfast-carb').value = bf ? (bf.carbsGrams || '') : '';

            document.getElementById('weekly-lunch-food').value = lu ? lu.foodContent : '';
            document.getElementById('weekly-lunch-cal').value = lu ? (lu.plannedCalories || '') : '';
            document.getElementById('weekly-lunch-prot').value = lu ? (lu.proteinGrams || '') : '';
            document.getElementById('weekly-lunch-carb').value = lu ? (lu.carbsGrams || '') : '';

            document.getElementById('weekly-snack-food').value = sn ? sn.foodContent : '';
            document.getElementById('weekly-snack-cal').value = sn ? (sn.plannedCalories || '') : '';
            document.getElementById('weekly-snack-prot').value = sn ? (sn.proteinGrams || '') : '';
            document.getElementById('weekly-snack-carb').value = sn ? (sn.carbsGrams || '') : '';
        }

        async function saveWeeklyMealPlans() {
            saveCurrentWeeklyDayInputsToData();

            const btn = document.getElementById('btn-save-weekly-plans');
            const originalText = btn.innerText;
            btn.innerText = "Kaydediliyor...";
            btn.disabled = true;
            btn.style.opacity = "0.7";

            try {
                const plansPayload = weeklyMealPlansData.map(p => ({
                    Id: p.id,
                    DayOfWeek: p.dayOfWeek,
                    MealName: p.mealName,
                    PlannedCalories: p.plannedCalories,
                    FoodContent: p.foodContent,
                    ProteinGrams: p.proteinGrams,
                    CarbsGrams: p.carbsGrams
                }));

                const response = await fetch('/Teacher/UpdateClassroomWeeklyMealPlan', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({
                        classroomId: '@classroom?.Id',
                        plans: plansPayload
                    })
                });

                const data = await response.json();
                if (data.success) {
                    btn.innerText = "✓ Şablon Kaydedildi!";
                    btn.style.background = "#10b981";
                    setTimeout(() => {
                        closeWeeklyMealPlanModal();
                        window.location.reload();
                    }, 1000);
                } else {
                    alert("Şablon kaydedilirken hata oluştu: " + data.message);
                    btn.innerText = originalText;
                    btn.disabled = false;
                    btn.style.opacity = "1";
                }
            } catch (err) {
                console.error(err);
                alert("İletişim hatası oluştu!");
                btn.innerText = originalText;
                btn.disabled = false;
                btn.style.opacity = "1";
            }
        }
    </script>
}
