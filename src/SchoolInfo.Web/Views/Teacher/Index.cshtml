@model List<SchoolInfo.Web.Models.ClassroomDto>
@{
    ViewData["Title"] = "Öğretmen Paneli";
}

<div class="teacher-workspace">
    <div>
        <h1 class="dashboard-title">Öğretmen Paneli</h1>
        <p class="dashboard-desc">Sorumlu olduğunuz sınıfları seçerek günlük gelişim kayıtlarını ve aktiviteleri yönetebilirsiniz.</p>
    </div>

    @if (ViewBag.ErrorMessage != null)
    {
        <div class="error-summary">@ViewBag.ErrorMessage</div>
    }

    <div class="glass-card">
        <div class="section-card-header">
            <h2>Sorumlu Olduğunuz Sınıflar (@Model.Count)</h2>
        </div>

        @if (Model.Count == 0)
        {
            <p style="color: var(--text-secondary); text-align: center; padding: 2rem;">Sorumlu olduğunuz herhangi bir sınıf atanmamış.</p>
        }
        else
        {
            <div class="classrooms-grid">
                @foreach (var classroom in Model)
                {
                    <div class="glass-card class-card" style="padding: 1.5rem;">
                        <div>
                            <span style="font-size: 0.75rem; color: var(--text-muted); text-transform: uppercase; font-weight: 600; letter-spacing: 0.05em;">Anaokulu Sınıfı</span>
                            <h3 style="margin-top: 0.25rem;">@classroom.Name</h3>
                        </div>
                        <div class="class-card-action">
                            <span style="font-size: 0.85rem; color: var(--text-secondary);">Aktif Eğitim</span>
                            <a asp-controller="Teacher" asp-action="ClassroomDetails" asp-route-id="@classroom.Id" class="card-link">Sınıf Defteri &rarr;</a>
                        </div>
                    </div>
                }
            </div>
        }
    </div>
</div>
