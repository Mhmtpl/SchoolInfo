<!-- YENİ BÜLTEN MODALI -->
<div id="newsletterModal" class="simple-modal">
    <div class="glass-card simple-modal-content">
        <div class="section-card-header" style="margin-bottom: 2rem;">
            <h2 id="newsletterModalTitle">Yeni Bülten Oluştur</h2>
            <button onclick="closeNewsletterModal()" style="background:none; border:none; color:var(--text-muted); font-size:1.5rem; cursor:pointer;">&times;</button>
