        let currentSelectedWeeklyDay = -1;
        let weeklyMealPlansData = [];

        async function openWeeklyMealPlanModal() {
            try {
                const response = await fetch(`/Teacher/GetWeeklyMealPlans?classroomId=@classroom?.Id`);
                const resData = await response.json();
                if (resData.success) {
                    weeklyMealPlansData = (resData.plans || []).map(p => ({
                        id: p.id || p.Id || p.ID || '00000000-0000-0000-0000-000000000000',
                        dayOfWeek: p.dayOfWeek !== undefined ? p.dayOfWeek : p.DayOfWeek,
                        mealName: p.mealName || p.MealName || '',
                        plannedCalories: p.plannedCalories !== undefined ? p.plannedCalories : p.PlannedCalories,
                        foodContent: p.foodContent || p.FoodContent || '',
                        proteinGrams: p.proteinGrams !== undefined ? p.proteinGrams : p.ProteinGrams,
                        carbsGrams: p.carbsGrams !== undefined ? p.carbsGrams : p.CarbsGrams
                    }));
                    initializeWeeklyDataDefaults();
                    document.getElementById('weeklyMealPlanModal').style.display = 'flex';
                    selectWeeklyDay(1);
                } else {
                    alert("Şablon verileri yüklenirken hata oluştu: " + resData.message);
                }
            } catch (err) {
                console.error(err);
                alert("Veriler alınırken iletişim hatası oluştu.");
            }
        }

        function closeWeeklyMealPlanModal() {
            document.getElementById('weeklyMealPlanModal').style.display = 'none';
            currentSelectedWeeklyDay = -1;
        }

        function initializeWeeklyDataDefaults() {
            const meals = ["Kahvaltı", "Öğle Yemeği", "İkindi Kahvaltısı"];
            for (let d = 1; d <= 5; d++) {
                meals.forEach(mName => {
                    const exists = weeklyMealPlansData.some(p => p.dayOfWeek === d && p.mealName.toLowerCase() === mName.toLowerCase());
                    if (!exists) {
                        weeklyMealPlansData.push({
                            id: '00000000-0000-0000-0000-000000000000',
                            dayOfWeek: d,
                            mealName: mName,
                            plannedCalories: 0,
                            foodContent: '',
                            proteinGrams: 0,
                            carbsGrams: 0
                        });
                    }
                });
            }
        }

        function selectWeeklyDay(dayNum) {
            saveCurrentWeeklyDayInputsToData();
            currentSelectedWeeklyDay = dayNum;

            for (let i = 1; i <= 5; i++) {
                const btn = document.getElementById(`btn-day-${i}`);
                if (btn) {
                    if (i === dayNum) {
                        btn.style.background = 'linear-gradient(135deg, #1e3c72 0%, #2a5298 100%)';
                        btn.style.color = 'white';
                        btn.style.boxShadow = '0 4px 10px rgba(30, 60, 114, 0.2)';
                    } else {
                        btn.style.background = 'transparent';
                        btn.style.color = '#4b5563';
                        btn.style.boxShadow = 'none';
                    }
                }
            }

            loadWeeklyDayInputsFromData(dayNum);
        }

        function saveCurrentWeeklyDayInputsToData() {
            if (currentSelectedWeeklyDay < 1 || currentSelectedWeeklyDay > 5) return;

            const bf = weeklyMealPlansData.find(p => p.dayOfWeek === currentSelectedWeeklyDay && p.mealName.toLowerCase().includes('kahvaltı') && !p.mealName.toLowerCase().includes('ikindi'));
            const lu = weeklyMealPlansData.find(p => p.dayOfWeek === currentSelectedWeeklyDay && p.mealName.toLowerCase().includes('öğle'));
            const sn = weeklyMealPlansData.find(p => p.dayOfWeek === currentSelectedWeeklyDay && p.mealName.toLowerCase().includes('ikindi'));

            if (bf) {
                bf.foodContent = document.getElementById('weekly-breakfast-food').value || '';
                bf.plannedCalories = parseInt(document.getElementById('weekly-breakfast-cal').value) || 0;
                bf.proteinGrams = parseFloat(document.getElementById('weekly-breakfast-prot').value) || 0;
                bf.carbsGrams = parseFloat(document.getElementById('weekly-breakfast-carb').value) || 0;
            }
            if (lu) {
                lu.foodContent = document.getElementById('weekly-lunch-food').value || '';
                lu.plannedCalories = parseInt(document.getElementById('weekly-lunch-cal').value) || 0;
                lu.proteinGrams = parseFloat(document.getElementById('weekly-lunch-prot').value) || 0;
                lu.carbsGrams = parseFloat(document.getElementById('weekly-lunch-carb').value) || 0;
            }
            if (sn) {
                sn.foodContent = document.getElementById('weekly-snack-food').value || '';
                sn.plannedCalories = parseInt(document.getElementById('weekly-snack-cal').value) || 0;
                sn.proteinGrams = parseFloat(document.getElementById('weekly-snack-prot').value) || 0;
                sn.carbsGrams = parseFloat(document.getElementById('weekly-snack-carb').value) || 0;
            }
        }

        function loadWeeklyDayInputsFromData(dayNum) {
            const bf = weeklyMealPlansData.find(p => p.dayOfWeek === dayNum && p.mealName.toLowerCase().includes('kahvaltı') && !p.mealName.toLowerCase().includes('ikindi'));
            const lu = weeklyMealPlansData.find(p => p.dayOfWeek === dayNum && p.mealName.toLowerCase().includes('öğle'));
            const sn = weeklyMealPlansData.find(p => p.dayOfWeek === dayNum && p.mealName.toLowerCase().includes('ikindi'));

            document.getElementById('weekly-breakfast-food').value = bf ? bf.foodContent : '';
            document.getElementById('weekly-breakfast-cal').value = bf ? (bf.plannedCalories || '') : '';
            document.getElementById('weekly-breakfast-prot').value = bf ? (bf.proteinGrams || '') : '';
            document.getElementById('weekly-breakfast-carb').value = bf ? (bf.carbsGrams || '') : '';

            document.getElementById('weekly-lunch-food').value = lu ? lu.foodContent : '';
            document.getElementById('weekly-lunch-cal').value = lu ? (lu.plannedCalories || '') : '';
            document.getElementById('weekly-lunch-prot').value = lu ? (lu.proteinGrams || '') : '';
            document.getElementById('weekly-lunch-carb').value = lu ? (lu.carbsGrams || '') : '';

            document.getElementById('weekly-snack-food').value = sn ? sn.foodContent : '';
            document.getElementById('weekly-snack-cal').value = sn ? (sn.plannedCalories || '') : '';
            document.getElementById('weekly-snack-prot').value = sn ? (sn.proteinGrams || '') : '';
            document.getElementById('weekly-snack-carb').value = sn ? (sn.carbsGrams || '') : '';
        }

