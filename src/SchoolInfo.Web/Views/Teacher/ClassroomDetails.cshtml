                                <span id="header-menu-lunch" style="font-size: 0.75rem; font-weight: 500; color: #1e3a8a; display: @(string.IsNullOrEmpty(lMenu) ? "none" : "block"); margin-top: 0.25rem; font-style: italic; background: rgba(59, 130, 246, 0.1); padding: 0.2rem; border-radius: 4px;">@lMenu</span>
                                <select onchange="bulkMealUpdate('lunch', this.value); this.value=''" style="margin-top: 0.4rem; font-size: 0.72rem; padding: 0.2rem 0.4rem; border-radius: 6px; border: 1px solid rgba(59,130,246,0.4); background: rgba(219,234,254,0.6); cursor: pointer; width: 100%; font-weight: normal;">
                                    <option value="">Toplu Seçim...</option>
                                    <option value="3">✅ Hepsini Yedi</option>
                                    <option value="2">🟡 Yarısını Yedi</option>
                                    <option value="1">🔶 Az Yedi</option>
                                    <option value="0">❌ Hiç Yemedi</option>
                                </select>
                            </th>
                            <th style="padding: 1.2rem 1rem; width: 26%; font-weight: 700; color: var(--text-primary); text-align: center; vertical-align: middle;">
                                <div>🧁 İkindi Kahvaltısı</div>
                                <span id="header-menu-snack" style="font-size: 0.75rem; font-weight: 500; color: #065f46; display: @(string.IsNullOrEmpty(sMenu) ? "none" : "block"); margin-top: 0.25rem; font-style: italic; background: rgba(16, 185, 129, 0.1); padding: 0.2rem; border-radius: 4px;">@sMenu</span>
                                <select onchange="bulkMealUpdate('snack', this.value); this.value=''" style="margin-top: 0.4rem; font-size: 0.72rem; padding: 0.2rem 0.4rem; border-radius: 6px; border: 1px solid rgba(16,185,129,0.4); background: rgba(209,250,229,0.6); cursor: pointer; width: 100%; font-weight: normal;">
                                    <option value="">Toplu Seçim...</option>
                                    <option value="3">✅ Hepsini Yedi</option>
                                    <option value="2">🟡 Yarısını Yedi</option>
                                    <option value="1">🔶 Az Yedi</option>
                                    <option value="0">❌ Hiç Yemedi</option>
                                </select>
                            </th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var student in detailedMeals)
                        {
                            var breakfast = student.Meals.FirstOrDefault(m => m.MealName.Contains("Kahvaltı", StringComparison.OrdinalIgnoreCase) && !m.MealName.Contains("İkindi", StringComparison.OrdinalIgnoreCase));
                            var lunch = student.Meals.FirstOrDefault(m => m.MealName.Contains("Öğle", StringComparison.OrdinalIgnoreCase));
                            var snack = student.Meals.FirstOrDefault(m => m.MealName.Contains("İkindi", StringComparison.OrdinalIgnoreCase));

                            int enteredMealsCount = student.Meals.Count(m => m.MealRecordId != Guid.Empty);
                            var rowId = student.StudentId.ToString();
                            var isStudentAbsent = dailyRecords.Any(r => r.StudentId == student.StudentId && r.IsAbsent);

                            <tr id="meal-row-tr-@rowId" style="border-bottom: 1px solid var(--border-color); transition: background 0.2s; @(isStudentAbsent ? "background: #fef2f2; opacity: 0.7;" : "")" onmouseover="this.style.background='rgba(240, 242, 245, 0.2)'" onmouseout="this.style.background='none'">
                                <td style="padding: 1.2rem 1rem;">
                                    <div class="student-info" style="font-weight: 600; color: var(--text-primary); font-size: 1rem;">
                                        @student.FirstName @student.LastName
                                        <span id="meal-badge-absent-@rowId" style="display: @(isStudentAbsent ? "inline-block" : "none"); margin-left: 0.5rem; font-size: 0.7rem; color: #dc2626; background: #fee2e2; padding: 0.1rem 0.4rem; border-radius: 4px; font-weight:600;">Devamsız</span>
                                    </div>
                                    <span id="meal-count-@rowId" style="font-size: 0.75rem; color: @(enteredMealsCount == 3 ? "#059669" : enteredMealsCount > 0 ? "var(--text-primary)" : "var(--text-muted)"); font-weight: @(enteredMealsCount > 0 ? "600" : "normal"); display: block; margin-top: 0.2rem;">
                                        @(enteredMealsCount == 0 ? "Öğün kaydı girilmedi" : $"Öğün kaydı girildi ({enteredMealsCount}/3)")
                                    </span>
                                </td>

                                <!-- KAHVALTI CELL -->
                                <td style="padding: 1rem; vertical-align: top;">
                                    @if (breakfast != null)
                                    {
                                        var bRecordId = breakfast.MealRecordId.ToString();
                                        <div class="meal-cell-container" style="background: rgba(254, 243, 199, 0.4); border: 1px solid rgba(251, 191, 36, 0.2); padding: 0.8rem; border-radius: 12px; display: flex; flex-direction: column; gap: 0.5rem;">
                                            <select id="meal-status-@rowId-breakfast" class="state-select meal-select-@rowId" @(isStudentAbsent ? "disabled" : "") style="width: 100%; padding: 0.4rem; border-radius: 8px; border: 1px solid rgba(0,0,0,0.1); font-size: 0.85rem;">
                                                @if (breakfast.MealRecordId == Guid.Empty)
                                                {
                                                    <option value="" selected disabled>Seçiniz...</option>
                                                }
                                                <option value="3" selected="@(breakfast.MealRecordId != Guid.Empty && breakfast.StatusType == 3)">Hepsini Yedi</option>
                                                <option value="2" selected="@(breakfast.MealRecordId != Guid.Empty && breakfast.StatusType == 2)">Yarısını Yedi</option>
                                                <option value="1" selected="@(breakfast.MealRecordId != Guid.Empty && breakfast.StatusType == 1)">Az Yedi</option>
                                                <option value="0" selected="@(breakfast.MealRecordId != Guid.Empty && breakfast.StatusType == 0)">Hiç Yemedi</option>
                                            </select>
                                            <input type="text" id="meal-note-@rowId-breakfast" class="note-input meal-input-@rowId" value="@(breakfast.MealRecordId != Guid.Empty ? breakfast.StatusDescription : "")" placeholder="@(isStudentAbsent ? "Öğrenci devamsız" : "Not ekleyin...")" @(isStudentAbsent ? "disabled" : "") style="width: 100%; padding: 0.4rem; border-radius: 8px; border: 1px solid rgba(0,0,0,0.08); font-size: 0.8rem;" />
                                            <button type="button" onclick="saveIndividualMeal('@rowId', '@bRecordId', 'Kahvaltı', 'breakfast')" id="btn-save-@rowId-breakfast" class="save-row-btn meal-btn-@rowId" style="width: 100%; padding: 0.4rem; font-size: 0.8rem; margin-top: 0.2rem; border-radius: 8px; border: none; background: #fbbf24; color: #78350f; font-weight: 600; cursor: pointer; transition: opacity 0.2s; display: @(isStudentAbsent ? "none" : "block");" @(isStudentAbsent ? "disabled" : "")>
                                                Kaydet
                                            </button>
                                        </div>
                                    }
                                    else
                                    {
                                        <div style="text-align: center; color: var(--text-muted); font-size: 0.85rem; padding: 1rem;">Öğün tanımlanmamış</div>
                                    }
                                </td>

                                <!-- ÖĞLE YEMEĞİ CELL -->
                                <td style="padding: 1rem; vertical-align: top;">
                                    @if (lunch != null)
                                    {
                                        var lRecordId = lunch.MealRecordId.ToString();
                                        <div class="meal-cell-container" style="background: rgba(219, 234, 254, 0.4); border: 1px solid rgba(59, 130, 246, 0.2); padding: 0.8rem; border-radius: 12px; display: flex; flex-direction: column; gap: 0.5rem;">
                                            <select id="meal-status-@rowId-lunch" class="state-select meal-select-@rowId" @(isStudentAbsent ? "disabled" : "") style="width: 100%; padding: 0.4rem; border-radius: 8px; border: 1px solid rgba(0,0,0,0.1); font-size: 0.85rem;">
                                                @if (lunch.MealRecordId == Guid.Empty)
                                                {
                                                    <option value="" selected disabled>Seçiniz...</option>
                                                }
                                                <option value="3" selected="@(lunch.MealRecordId != Guid.Empty && lunch.StatusType == 3)">Hepsini Yedi</option>
                                                <option value="2" selected="@(lunch.MealRecordId != Guid.Empty && lunch.StatusType == 2)">Yarısını Yedi</option>
                                                <option value="1" selected="@(lunch.MealRecordId != Guid.Empty && lunch.StatusType == 1)">Az Yedi</option>
                                                <option value="0" selected="@(lunch.MealRecordId != Guid.Empty && lunch.StatusType == 0)">Hiç Yemedi</option>
                                            </select>
                                            <input type="text" id="meal-note-@rowId-lunch" class="note-input meal-input-@rowId" value="@(lunch.MealRecordId != Guid.Empty ? lunch.StatusDescription : "")" placeholder="@(isStudentAbsent ? "Öğrenci devamsız" : "Not ekleyin...")" @(isStudentAbsent ? "disabled" : "") style="width: 100%; padding: 0.4rem; border-radius: 8px; border: 1px solid rgba(0,0,0,0.08); font-size: 0.8rem;" />
                                            <button type="button" onclick="saveIndividualMeal('@rowId', '@lRecordId', 'Öğle Yemeği', 'lunch')" id="btn-save-@rowId-lunch" class="save-row-btn meal-btn-@rowId" style="width: 100%; padding: 0.4rem; font-size: 0.8rem; margin-top: 0.2rem; border-radius: 8px; border: none; background: #3b82f6; color: white; font-weight: 600; cursor: pointer; transition: opacity 0.2s; display: @(isStudentAbsent ? "none" : "block");" @(isStudentAbsent ? "disabled" : "")>
                                                Kaydet
                                            </button>
                                        </div>
                                    }
                                    else
                                    {
                                        <div style="text-align: center; color: var(--text-muted); font-size: 0.85rem; padding: 1rem;">Öğün tanımlanmamış</div>
                                    }
                                </td>

                                <!-- İKİNDİ CELL -->
                                <td style="padding: 1rem; vertical-align: top;">
                                    @if (snack != null)
                                    {
                                        var sRecordId = snack.MealRecordId.ToString();
                                        <div class="meal-cell-container" style="background: rgba(243, 244, 246, 0.8); border: 1px solid rgba(156, 163, 175, 0.2); padding: 0.8rem; border-radius: 12px; display: flex; flex-direction: column; gap: 0.5rem;">
                                            <select id="meal-status-@rowId-snack" class="state-select meal-select-@rowId" @(isStudentAbsent ? "disabled" : "") style="width: 100%; padding: 0.4rem; border-radius: 8px; border: 1px solid rgba(0,0,0,0.1); font-size: 0.85rem;">
                                                @if (snack.MealRecordId == Guid.Empty)
                                                {
                                                    <option value="" selected disabled>Seçiniz...</option>
                                                }
                                                <option value="3" selected="@(snack.MealRecordId != Guid.Empty && snack.StatusType == 3)">Hepsini Yedi</option>
                                                <option value="2" selected="@(snack.MealRecordId != Guid.Empty && snack.StatusType == 2)">Yarısını Yedi</option>
                                                <option value="1" selected="@(snack.MealRecordId != Guid.Empty && snack.StatusType == 1)">Az Yedi</option>
                                                <option value="0" selected="@(snack.MealRecordId != Guid.Empty && snack.StatusType == 0)">Hiç Yemedi</option>
                                            </select>
                                            <input type="text" id="meal-note-@rowId-snack" class="note-input meal-input-@rowId" value="@(snack.MealRecordId != Guid.Empty ? snack.StatusDescription : "")" placeholder="@(isStudentAbsent ? "Öğrenci devamsız" : "Not ekleyin...")" @(isStudentAbsent ? "disabled" : "") style="width: 100%; padding: 0.4rem; border-radius: 8px; border: 1px solid rgba(0,0,0,0.08); font-size: 0.8rem;" />
                                            <button type="button" onclick="saveIndividualMeal('@rowId', '@sRecordId', 'İkindi Kahvaltısı', 'snack')" id="btn-save-@rowId-snack" class="save-row-btn meal-btn-@rowId" style="width: 100%; padding: 0.4rem; font-size: 0.8rem; margin-top: 0.2rem; border-radius: 8px; border: none; background: #10b981; color: white; font-weight: 600; cursor: pointer; transition: opacity 0.2s; display: @(isStudentAbsent ? "none" : "block");" @(isStudentAbsent ? "disabled" : "")>
                                                Kaydet
                                            </button>
                                        </div>
                                    }
                                    else
                                    {
                                        <div style="text-align: center; color: var(--text-muted); font-size: 0.85rem; padding: 1rem;">Öğün tanımlanmamış</div>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div> <!-- END TAB 4 -->
</div>

<!-- YENİ AKTİVİTE EKLEME MODALI -->
<div id="activityModal" class="simple-modal">
    <div class="glass-card simple-modal-content">
        <div class="section-card-header" style="margin-bottom: 2rem;">
            <h2>Yeni Aktivite Oluştur</h2>
            <button onclick="closeModal()" style="background:none; border:none; color:var(--text-muted); font-size:1.5rem; cursor:pointer;">&times;</button>
        </div>

        <form asp-action="CreateActivity" method="post">
            <input type="hidden" name="classroomId" value="@classroom?.Id" />

            <div class="form-group">
                <label for="title">Aktivite Adı</label>
                <select id="title" name="title" class="form-control" required>
                    <option value="Fen ve Doğa Etkinliği">Fen ve Doğa Etkinliği</option>
                    <option value="Sanat Etkinliği">Sanat Etkinliği</option>
                    <option value="Oyun Etkinliği">Oyun Etkinliği</option>
                    <option value="Türkçe Etkinliği">Türkçe Etkinliği</option>
                    <option value="Müzik Etkinliği">Müzik Etkinliği</option>
                    <option value="Drama Etkinliği">Drama Etkinliği</option>
                    <option value="Serbest Zaman">Serbest Zaman</option>
                    <option value="Kahvaltı">Kahvaltı</option>
                    <option value="Öğle Yemeği">Öğle Yemeği</option>
                    <option value="İkindi Kahvaltısı">İkindi Kahvaltısı</option>
                    <option value="Uyku / Dinlenme">Uyku / Dinlenme</option>
                </select>
            </div>

            <div class="form-group">
                <label for="description">Açıklama</label>
                <textarea id="description" name="description" class="form-control" style="height: 100px; resize: none;" placeholder="Aktivite detayları..." required></textarea>
            </div>

            <div class="form-group">
                <label for="activityDate">Etkinlik Tarihi</label>
                <input type="date" id="activityDate" name="activityDate" class="form-control" value="@DateTime.UtcNow.AddHours(3).ToString("yyyy-MM-dd")" required />
            </div>

            <div class="form-group" style="display: flex; gap: 1rem;">
                <div style="flex: 1;">
                    <label for="startTime">Başlangıç</label>
                    <input type="time" id="startTime" name="startTime" class="form-control" required />
                </div>
                <div style="flex: 1;">
                    <label for="endTime">Bitiş</label>
                    <input type="time" id="endTime" name="endTime" class="form-control" required />
                </div>
            </div>

            <div class="form-group">
                <label for="type">Aktivite Tipi</label>
                <select id="type" name="type" class="form-control" required>
                    <option value="0">Ders/Eğitim</option>
                    <option value="1">Oyun/Serbest Zaman</option>
                    <option value="2">Yemek</option>
                    <option value="3">Uyku/Dinlenme</option>
                    <option value="4">Sanat/Atölye</option>
                </select>
            </div>

            <div style="display: flex; gap: 1rem; margin-top: 2rem;">
                <button type="button" onclick="closeModal()" class="btn-secondary" style="flex: 1;">İptal</button>
                <button type="submit" class="btn-primary" style="flex: 1; margin-top: 0;">Oluştur</button>
            </div>
        </form>
    </div>
</div>

<!-- HAFTALIK ŞABLON MODAL -->
<div id="weeklyScheduleModal" class="simple-modal">
    <div class="glass-card simple-modal-content" style="max-width: 900px;">
        <div class="section-card-header" style="margin-bottom: 1.5rem;">
            <h2>Sabit Haftalık Ders Şablonu</h2>
            <button onclick="closeWeeklyScheduleModal()" style="background:none; border:none; color:var(--text-muted); font-size:1.5rem; cursor:pointer;">&times;</button>
        </div>
        <div>
            <p style="color: var(--text-secondary); margin-bottom: 1rem; font-size: 0.9rem;">
                Bu şablon, "Şablonu Uygula" dediğinizde ilgili haftanın tüm günlerine otomatik olarak eklenecek olan dersleri belirler.
            </p>
            
            <div style="display: flex; gap: 0.5rem; margin-bottom: 1.5rem; border-bottom: 2px solid var(--border-color); padding-bottom: 0.5rem; overflow-x: auto;">
                <button type="button" onclick="switchTemplateDay(1)" id="btn-tmpl-1" class="tmpl-tab-btn active" style="background: none; border: none; font-weight: 700; color: var(--primary-color); border-bottom: 3px solid var(--primary-color); padding: 0.5rem 1rem; cursor: pointer; transition: all 0.2s;">Pazartesi</button>
                <button type="button" onclick="switchTemplateDay(2)" id="btn-tmpl-2" class="tmpl-tab-btn" style="background: none; border: none; font-weight: 700; color: var(--text-muted); border-bottom: 3px solid transparent; padding: 0.5rem 1rem; cursor: pointer; transition: all 0.2s;">Salı</button>
                <button type="button" onclick="switchTemplateDay(3)" id="btn-tmpl-3" class="tmpl-tab-btn" style="background: none; border: none; font-weight: 700; color: var(--text-muted); border-bottom: 3px solid transparent; padding: 0.5rem 1rem; cursor: pointer; transition: all 0.2s;">Çarşamba</button>
                <button type="button" onclick="switchTemplateDay(4)" id="btn-tmpl-4" class="tmpl-tab-btn" style="background: none; border: none; font-weight: 700; color: var(--text-muted); border-bottom: 3px solid transparent; padding: 0.5rem 1rem; cursor: pointer; transition: all 0.2s;">Perşembe</button>
                <button type="button" onclick="switchTemplateDay(5)" id="btn-tmpl-5" class="tmpl-tab-btn" style="background: none; border: none; font-weight: 700; color: var(--text-muted); border-bottom: 3px solid transparent; padding: 0.5rem 1rem; cursor: pointer; transition: all 0.2s;">Cuma</button>
            </div>
            
            <div id="weeklyScheduleContainer" style="display: flex; flex-direction: column; gap: 1rem; margin-bottom: 1rem;">
                <!-- JS ile satırlar buraya eklenecek -->
            </div>
            
            <button type="button" onclick="addWeeklyScheduleRow()" class="btn-secondary" style="margin-bottom: 1rem; width: 100%; border: 2px dashed var(--primary-color); color: var(--primary-color); background: rgba(245, 158, 11, 0.05);">+ Bu Güne Yeni Ders Ekle</button>
            
            <div style="display: flex; justify-content: flex-end; gap: 1rem; margin-top: 1rem; border-top: 1px solid var(--border-color); padding-top: 1rem;">
                <button type="button" onclick="closeWeeklyScheduleModal()" class="btn-secondary">İptal</button>
                <button type="button" onclick="saveWeeklySchedule()" class="btn-primary">Şablonu Kaydet</button>
            </div>
        </div>
    </div>
</div>

<!-- YENİ BÜLTEN MODALI -->
<div id="newsletterModal" class="simple-modal">
    <div class="glass-card simple-modal-content">
        <div class="section-card-header" style="margin-bottom: 2rem;">
            <h2 id="newsletterModalTitle">Yeni Bülten Oluştur</h2>
            <button onclick="closeNewsletterModal()" style="background:none; border:none; color:var(--text-muted); font-size:1.5rem; cursor:pointer;">&times;</button>
        </div>

        <form asp-controller="Newsletter" asp-action="CreateNewsletter" method="post" id="newsletterForm" enctype="multipart/form-data">
            <input type="hidden" name="classroomId" value="@classroom?.Id" />
            <input type="hidden" id="newsletterId" name="id" value="" />

            <div style="display: flex; gap: 1rem;">
                <div class="form-group" style="flex: 2;">
                    <label for="newsletterTitle">Bülten Başlığı</label>
                    <input type="text" id="newsletterTitle" name="title" class="form-control" placeholder="Örn: Ekim 2. Hafta Bülteni" required />
                </div>
                <div class="form-group" style="flex: 1;">
                    <label for="newsletterWeekName">Hafta (Opsiyonel)</label>
                    <input type="text" id="newsletterWeekName" name="weekName" class="form-control" placeholder="Örn: 9-13 Ekim" />
                </div>
                <div class="form-group" style="flex: 1; min-width: 140px;">
                    <label for="newsletterTheme">Şablon Teması</label>
                    <select id="newsletterTheme" name="theme" class="form-control" onchange="updateThemePreview(this.value)">
                        <option value="Default">Klasik (Lacivert)</option>
                        <option value="Playful">Eğlenceli (Pembe/Mor)</option>
                        <option value="Nature">Doğa (Yeşil/Nane)</option>
                        <option value="Sunset">Gün Batımı (Turuncu/Altın)</option>
                    </select>
                    <div id="themePreview" style="margin-top: 0.4rem; display: flex; gap: 0.4rem; align-items: center; background: rgba(0,0,0,0.03); padding: 0.25rem 0.5rem; border-radius: 6px;">
                        <span style="font-size: 0.72rem; font-weight: 600; color: var(--text-muted);">Renkler:</span>
                        <div id="themeColor1" style="width: 12px; height: 12px; border-radius: 50%; border: 1px solid rgba(0,0,0,0.1); background: #0F172A; transition: all 0.2s;"></div>
                        <div id="themeColor2" style="width: 12px; height: 12px; border-radius: 50%; border: 1px solid rgba(0,0,0,0.1); background: #E94560; transition: all 0.2s;"></div>
                    </div>
                </div>
            </div>

            <div class="form-group">
                <label for="coverImage">Görsel Yükle (PC/Mobil)</label>
                <input type="hidden" id="imageUrl" name="imageUrl" />
                <input type="file" id="coverImage" name="CoverImage" class="form-control" accept="image/*" />
                <small style="color: var(--text-muted); display: block; margin-top: 0.3rem;">Yeni görsel seçerseniz eski görselin üzerine yazılır.</small>
            </div>

            <div class="form-group">
                <label for="newsletterContent">Genel Özet / Mesaj</label>
                <textarea id="newsletterContent" name="content" class="form-control" style="height: 80px; resize: none;" placeholder="Velilerimize genel notlar..." required></textarea>
            </div>

            <div class="section-card-header" style="margin-top: 1.5rem; margin-bottom: 1rem; border-top: 1px solid var(--border-color); padding-top: 1rem;">
                <h3 style="font-size: 1.1rem;">Bülten Konuları (Aktivite Raporları)</h3>
                <button type="button" onclick="addNewsletterSection()" style="background: none; border: none; color: var(--primary-color); font-weight: 600; cursor: pointer; font-size: 0.85rem;">+ Konu Ekle</button>
            </div>

            <div id="newsletterSectionsContainer">
                <!-- Dinamik Bölümler Buraya Gelecek -->
            </div>

            <div style="display: flex; gap: 1rem; margin-top: 2rem;">
                <button type="button" onclick="closeNewsletterModal()" class="btn-secondary" style="flex: 1;">İptal</button>
                <button type="submit" class="btn-primary" style="flex: 1; margin-top: 0;">Taslak Olarak Kaydet</button>
            </div>
        </form>
    </div>
</div>

<!-- DİNAMİK MENÜ PLANLAMA MODALI -->
<div id="mealPlanModal" style="display: none; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.5); backdrop-filter: blur(8px); z-index: 1000; align-items: center; justify-content: center;">
    <div class="glass-card" style="width: 90%; max-width: 650px; background: rgba(255, 255, 255, 0.95); border-radius: 24px; border: 1px solid rgba(255,255,255,0.4); box-shadow: 0 20px 50px rgba(0,0,0,0.15); padding: 2rem; position: relative; max-height: 90vh; overflow-y: auto;">
        
        <button type="button" onclick="closeMealPlanModal()" style="position: absolute; top: 1.2rem; right: 1.2rem; background: none; border: none; font-size: 1.5rem; cursor: pointer; color: var(--text-muted); transition: color 0.2s;" onmouseover="this.style.color='var(--text-primary)'" onmouseout="this.style.color='var(--text-muted)'">&times;</button>
        
        <h2 style="font-size: 1.6rem; font-weight: 800; background: linear-gradient(135deg, #1e3c72 0%, #2a5298 100%); -webkit-background-clip: text; -webkit-text-fill-color: transparent; margin-bottom: 0.5rem; display: flex; align-items: center; gap: 0.5rem;">
            Planlanan Menüyü Düzenle 📝
        </h2>
        <p style="color: var(--text-secondary); font-size: 0.85rem; margin-bottom: 1.5rem;">Sınıfın bugünkü tüm yemek planlarını buradan güncelleyin.</p>
        
        <form id="mealPlanForm" style="display: flex; flex-direction: column; gap: 1.5rem;">
            
            <!-- KAHVALTI BÖLÜMÜ -->
            <div style="background: rgba(254, 243, 199, 0.35); border: 1px solid rgba(251, 191, 36, 0.2); padding: 1.2rem; border-radius: 16px;">
                <h3 style="font-size: 1rem; font-weight: 700; color: #78350f; margin-bottom: 0.8rem; display: flex; align-items: center; gap: 0.4rem;">🍳 Kahvaltı Planı</h3>
                <div style="display: grid; grid-template-columns: 2fr 1fr 1fr 1fr; gap: 0.75rem;">
