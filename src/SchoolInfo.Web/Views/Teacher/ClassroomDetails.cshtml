        async function saveWeeklySchedule() {
            const rows = document.querySelectorAll('.weekly-schedule-row');
            const schedules = [];

            function inferType(title) {
                if (title === 'Oyun Etkinliği' || title === 'Serbest Zaman') return 1;
                if (title === 'Kahvaltı' || title === 'Öğle Yemeği' || title === 'İkindi Kahvaltısı') return 2;
                if (title === 'Uyku / Dinlenme') return 3;
                if (title === 'Sanat Etkinliği' || title === 'Drama Etkinliği' || title === 'Müzik Etkinliği') return 4;
                return 0; // Default: Ders
            }

            rows.forEach(row => {
                let sTime = row.querySelector('.ws-start').value;
                if (sTime.length === 5) sTime += ':00';
                let eTime = row.querySelector('.ws-end').value;
                if (eTime.length === 5) eTime += ':00';
                let title = row.querySelector('.ws-title').value;

                schedules.push({
                    dayOfWeek: parseInt(row.getAttribute('data-day')),
                    title: title,
                    description: row.querySelector('.ws-desc').value,
                    startTime: sTime,
                    endTime: eTime,
                    type: inferType(title)
                });
            });

            try {
                const res = await fetch(`/api/classrooms/${classroomId}/weekly-schedule`, {
                    method: 'PUT',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ schedules: schedules })
                });

                if (res.ok) {
                    alert("Haftalık şablon kaydedildi!");
                    closeWeeklyScheduleModal();
                } else {
                    alert("Şablon kaydedilirken bir hata oluştu.");
                }
            } catch (err) {
                console.error(err);
                alert("İletişim hatası.");
            }
        }

