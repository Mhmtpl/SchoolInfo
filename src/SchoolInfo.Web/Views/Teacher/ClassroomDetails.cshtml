@section Scripts {
    <script>
        const classroomId = '@classroom?.Id';

        function changeClassroomDate(val) {
            const urlParams = new URLSearchParams(window.location.search);
            urlParams.set('date', val);
            window.location.search = urlParams.toString();
        }

        async function toggleAbsent(studentId, isAbsent) {
            const datePicker = document.getElementById('classroom-date-picker');
            const selectedDate = datePicker ? datePicker.value : new Date().toISOString().split('T')[0];

            try {
                const response = await fetch('/Teacher/ToggleAttendance', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json'
                    },
                    body: JSON.stringify({
                        studentId: studentId,
                        date: selectedDate,
                        isAbsent: isAbsent
                    })
                });

                const result = await response.json();
                if (result.success) {
                    // Update Daily Record row class and disable/enable inputs
                    const row = document.getElementById(`row-${studentId}`);
                    const sleepEl = document.getElementById(`sleep-${studentId}`);
                    const waterEl = document.getElementById(`water-${studentId}`);
                    const noteEl = document.getElementById(`note-${studentId}`);
                    const btnSave = document.getElementById(`btn-save-${studentId}`);
                    const spanNoAction = document.getElementById(`span-noaction-${studentId}`);
                    const badgeAbsent = document.getElementById(`badge-absent-${studentId}`);

                    if (isAbsent) {
                        if (row) row.classList.add('absent-row');
                        if (sleepEl) sleepEl.disabled = true;
                        if (waterEl) {
                            waterEl.disabled = true;
                            waterEl.value = '0';
                        }
                        if (noteEl) {
                            noteEl.disabled = true;
                            noteEl.value = 'Öğrenci devamsız';
                            noteEl.placeholder = 'Öğrenci devamsız';
                        }
                        if (btnSave) btnSave.style.display = 'none';
                        if (spanNoAction) spanNoAction.style.display = 'inline';
                        if (badgeAbsent) badgeAbsent.style.display = 'inline-block';
                    } else {
                        if (row) row.classList.remove('absent-row');
                        if (sleepEl) sleepEl.disabled = false;
                        if (waterEl) {
                            waterEl.disabled = false;
                            waterEl.value = '';
                        }
                        if (noteEl) {
                            noteEl.disabled = false;
                            noteEl.value = '';
                            noteEl.placeholder = 'Gelişim notları...';
                        }
                        if (btnSave) btnSave.style.display = 'inline-block';
                        if (spanNoAction) spanNoAction.style.display = 'none';
                        if (badgeAbsent) badgeAbsent.style.display = 'none';
                    }

                    // Lockout/unlock elements in Meal Tracking tab
                    const mealRow = document.getElementById(`meal-row-tr-${studentId}`);
                    const mealBadgeAbsent = document.getElementById(`meal-badge-absent-${studentId}`);
                    if (mealRow) {
                        if (isAbsent) {
                            mealRow.style.background = '#fef2f2';
                            mealRow.style.opacity = '0.7';
                        } else {
                            mealRow.style.background = 'none';
                            mealRow.style.opacity = '1';
                        }
                    }
                    if (mealBadgeAbsent) {
                        mealBadgeAbsent.style.display = isAbsent ? 'inline-block' : 'none';
                    }

                    // Selects, inputs and buttons under Meal Tracking for this student
                    document.querySelectorAll(`.meal-select-${studentId}`).forEach(el => el.disabled = isAbsent);
                    document.querySelectorAll(`.meal-input-${studentId}`).forEach(el => {
                        el.disabled = isAbsent;
                        if (isAbsent) {
                            el.placeholder = 'Öğrenci devamsız';
                            el.value = '';
                        } else {
                            el.placeholder = 'Not ekleyin...';
                        }
                    });
                    document.querySelectorAll(`.meal-btn-${studentId}`).forEach(el => {
                        el.disabled = isAbsent;
                        el.style.display = isAbsent ? 'none' : 'block';
                    });

                    // Lockout/unlock elements in Medication Records tab
                    document.querySelectorAll(`.med-checkbox-${studentId}`).forEach(el => el.disabled = isAbsent);
                    document.querySelectorAll(`.med-delete-btn-${studentId}`).forEach(el => {
                        el.disabled = isAbsent;
                        el.style.display = isAbsent ? 'none' : 'inline-block';
                    });
                    const btnAddMed = document.getElementById(`btn-add-med-${studentId}`);
                    if (btnAddMed) btnAddMed.disabled = isAbsent;

                    const medBadge = document.getElementById(`med-badge-absent-${studentId}`);
                    if (medBadge) medBadge.style.display = isAbsent ? 'inline-block' : 'none';

                } else {
                    alert('Yoklama durumu güncellenirken hata oluştu: ' + result.message);
                }
            } catch (err) {
                console.error(err);
                alert('Sistemsel bir hata oluştu.');
            }
        }

        // Modern Tab Navigation
