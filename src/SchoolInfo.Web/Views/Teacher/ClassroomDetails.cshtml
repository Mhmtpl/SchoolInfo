        // Toplu Güncelleme (Bulk Update) İşlemi
        function bulkUpdate(type, value) {
            if (value === "") return;
            let selector = "";
            if (type === 'sleep') selector = "select[id^='sleep-']";
            if (type === 'water') selector = "input[id^='water-']";
            
            if (!selector) return;

            const elements = document.querySelectorAll(selector);
            elements.forEach(el => {
                if (!el.disabled) {
                    el.value = value;
                }
            });
        }

        // Tümünü Kaydet Butonu
        async function saveAllRows() {
            const rows = document.querySelectorAll('tr[id^="row-"]');
            let invalidStudents = [];
            
            rows.forEach(row => {
                const studentId = row.id.replace('row-', '');
                const sleepEl = document.getElementById(`sleep-${studentId}`);
                const waterEl = document.getElementById(`water-${studentId}`);
                
                // Devamsız olanları veya elemanı bulunmayanları atla
                if (!sleepEl || !waterEl) return;
                const isAbsent = row.classList.contains('absent-row') || sleepEl.disabled;
                if (isAbsent) return;
                
                if (sleepEl.value === "") {
                    const studentName = row.querySelector('.student-info').innerText.split('\n')[0].trim();
                    invalidStudents.push(`${studentName} (Uyku Durumu seçilmedi)`);
                }
                if (waterEl.value === "" || isNaN(parseInt(waterEl.value))) {
                    const studentName = row.querySelector('.student-info').innerText.split('\n')[0].trim();
                    invalidStudents.push(`${studentName} (Su miktarı girilmedi)`);
                }
            });
            
            if (invalidStudents.length > 0) {
                alert("Lütfen aşağıdaki öğrencilerin eksik bilgilerini tamamlayın:\n\n" + invalidStudents.join("\n"));
                return;
            }
            
            // Kullanıcıyı bilgilendir
            if(!confirm("Ekranda görünen aktif tüm öğrencilerin kayıtları aynı anda kaydedilecek. Onaylıyor musunuz?")) return;

            // Sırayla butonların tıklanma işlevini tetikle
            const btns = document.querySelectorAll('button[id^="btn-save-"]:not([id$="-breakfast"]):not([id$="-lunch"]):not([id$="-snack"]):not([id="btn-save-meal-plan"]):not([id="btn-save-weekly-plans"])');
            btns.forEach(btn => {
                if(!btn.disabled) {
                    btn.click();
                }
            });
        }

        // AJAX ile Günlük Gelişim Kaydetme
        async function saveRow(studentId) {
            const btn = document.getElementById(`btn-save-${studentId}`);
            btn.innerText = "Kaydediliyor...";
            btn.disabled = true;

            const sleepEl = document.getElementById(`sleep-${studentId}`);
            if (sleepEl.value === "") {
                alert("Lütfen öğrencinin uyku durumunu seçiniz.");
                btn.innerText = "Tekrar Dene";
                btn.disabled = false;
                return;
            }
            const sleepStatus = parseInt(sleepEl.value);

            const waterEl = document.getElementById(`water-${studentId}`);
            if (waterEl.value === "" || isNaN(parseInt(waterEl.value))) {
                alert("Lütfen su tüketim miktarını giriniz (0 veya daha fazla).");
                btn.innerText = "Tekrar Dene";
                btn.disabled = false;
                return;
            }
            const waterIntake = parseInt(waterEl.value);
            
            const note = document.getElementById(`note-${studentId}`).value;

            try {
                // 1. Günlük Özbakım Kaydını Güncelle
                const dailyRes = await fetch('/Teacher/UpdateDailyRecord', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({
                        studentId: studentId,
                        sleepStatus: sleepStatus,
                        waterConsumptionInMl: waterIntake,
                        teacherNote: note
                    })
                });
                const dailyData = await dailyRes.json();

                if (dailyData.success) {
                    btn.innerText = "Kaydedildi!";
                    btn.classList.add('success');
                    
                    // DOM durumunu güncelle
                    const statusSpan = document.getElementById(`record-status-${studentId}`);
                    if (statusSpan) {
                        statusSpan.innerText = "Kayıt girildi";
                        statusSpan.style.color = "#059669";
                        statusSpan.style.fontWeight = "600";
                    }

                    // Seçiniz placeholder seçeneğini temizle
                    const placeholderOpt = sleepEl.querySelector('option[value=""][disabled]');
                    if (placeholderOpt) {
                        placeholderOpt.remove();
                    }

                    setTimeout(() => {
                        btn.innerText = "Kaydet";
                        btn.classList.remove('success');
                        btn.disabled = false;
                    }, 2000);
                } else {
                    alert("Kayıt işlemi sırasında bir hata oluştu: " + dailyData.message);
                    btn.innerText = "Tekrar Dene";
                    btn.disabled = false;
                }
            } catch (err) {
                console.error(err);
                alert("İletişim hatası oluştu.");
                btn.innerText = "Tekrar Dene";
                btn.disabled = false;
            }
        }
