        async function saveIndividualMeal(studentId, mealRecordId, mealName, mealSlug) {
            const btn = document.getElementById(`btn-save-${studentId}-${mealSlug}`);
            const originalText = btn.innerText;
            
            const selectEl = document.getElementById(`meal-status-${studentId}-${mealSlug}`);
            const statusVal = selectEl.value;
            if (statusVal === "") {
                alert("Lütfen bir öğün tüketim durumu seçiniz.");
                return;
            }
            const status = parseInt(statusVal);
            const note = document.getElementById(`meal-note-${studentId}-${mealSlug}`).value;

            btn.innerText = "Kaydediliyor...";
            btn.disabled = true;
            btn.style.opacity = "0.7";

            try {
                const response = await fetch('/Teacher/UpdateMealRecord', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({
                        studentId: studentId,
                        mealRecordId: mealRecordId,
                        mealName: mealName,
                        statusType: status,
                        statusDescription: note
                    })
                });
                
                const data = await response.json();

                if (data.success) {
                    btn.innerText = "✓ Kaydedildi!";
                    btn.style.background = "#10b981";
                    btn.style.color = "white";
                    
                    // Remove the placeholder option if it exists
                    const placeholderOpt = selectEl.querySelector('option[value=""]');
                    if (placeholderOpt) {
                        placeholderOpt.remove();
                    }
                    
                    // Calculate the new entered count and update the label dynamically
                    let enteredCount = 0;
                    const slugs = ['breakfast', 'lunch', 'snack'];
                    slugs.forEach(slug => {
                        const sel = document.getElementById(`meal-status-${studentId}-${slug}`);
                        if (sel) {
                            if (sel.value !== "") {
                                enteredCount++;
                            }
                        }
                    });
                    
                    const countLabel = document.getElementById(`meal-count-${studentId}`);
                    if (countLabel) {
                        if (enteredCount === 0) {
                            countLabel.innerText = "Öğün kaydı girilmedi";
                            countLabel.style.color = "var(--text-muted)";
                            countLabel.style.fontWeight = "normal";
                        } else {
                            countLabel.innerText = `Öğün kaydı girildi (${enteredCount}/3)`;
                            if (enteredCount === 3) {
                                countLabel.style.color = "#059669";
                                countLabel.style.fontWeight = "600";
                            } else {
                                countLabel.style.color = "var(--text-primary)";
                                countLabel.style.fontWeight = "600";
                            }
                        }
                    }

                    setTimeout(() => {
                        btn.innerText = originalText;
                        // Reset background color according to meal type
                        if (mealName.includes("Kahvaltı")) {
                            btn.style.background = "#fbbf24";
                            btn.style.color = "#78350f";
                        } else if (mealName.includes("Öğle")) {
                            btn.style.background = "#3b82f6";
                            btn.style.color = "white";
                        } else {
                            btn.style.background = "#10b981";
                            btn.style.color = "white";
                        }
                        btn.disabled = false;
                        btn.style.opacity = "1";
                    }, 2000);
                } else {
                    alert("Öğün kaydedilirken bir hata oluştu: " + data.message);
                    btn.innerText = "Hata! Tekrar Dene";
                    btn.style.background = "#ef4444";
                    btn.style.color = "white";
                    btn.disabled = false;
                    btn.style.opacity = "1";
                }
            } catch (err) {
                console.error(err);
                alert("İletişim hatası oluştu!");
                btn.innerText = "Tekrar Dene";
                btn.disabled = false;
                btn.style.opacity = "1";
            }
        }

