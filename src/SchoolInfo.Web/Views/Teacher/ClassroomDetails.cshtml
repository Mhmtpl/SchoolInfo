                                <span id="header-menu-breakfast" style="font-size: 0.75rem; font-weight: 500; color: #78350f; display: @(string.IsNullOrEmpty(bMenu) ? "none" : "block"); margin-top: 0.25rem; font-style: italic; background: rgba(251, 191, 36, 0.1); padding: 0.2rem; border-radius: 4px;">@bMenu</span>
