            urlParams.set('date', val);
            window.location.search = urlParams.toString();
        }

        // --- YAPAY ZEKA TOPLU VERİ GİRİŞİ (AI) ---
        let voiceRecognition = null;
        let isRecording = false;

        function toggleVoiceRecord() {
            const btn = document.getElementById('btn-record-voice');
            const pulse = document.getElementById('voice-pulse');
            const statusText = document.getElementById('ai-status-text');
            const input = document.getElementById('ai-command-input');

            const SpeechRecognition = window.SpeechRecognition || window.webkitSpeechRecognition;
            if (!SpeechRecognition) {
                alert("Tarayıcınız ses tanıma özelliğini desteklemiyor. Lütfen Google Chrome veya Edge kullanın.");
                return;
            }

            if (!voiceRecognition) {
                voiceRecognition = new SpeechRecognition();
                voiceRecognition.lang = 'tr-TR';
                voiceRecognition.continuous = false;
                voiceRecognition.interimResults = false;

                voiceRecognition.onstart = () => {
                    isRecording = true;
                    btn.style.background = 'linear-gradient(135deg, #10b981, #059669)'; // Yeşile döndür
                    pulse.style.display = 'block';
                    statusText.innerHTML = '🎙️ Dinleniyor... Konuşun...';
                };

                voiceRecognition.onresult = (event) => {
                    const transcript = event.results[0][0].transcript;
                    if (input.value) {
                        input.value += ' ' + transcript;
                    } else {
                        input.value = transcript;
                    }
                    statusText.innerHTML = '✓ Ses başarıyla metne çevrildi.';
                };

                voiceRecognition.onerror = (event) => {
                    console.error("Speech recognition error:", event.error);
                    statusText.innerHTML = '❌ Ses alınırken bir hata oluştu: ' + event.error;
                    stopRecordingUI();
                };

                voiceRecognition.onend = () => {
                    stopRecordingUI();
                };
            }

            if (isRecording) {
                voiceRecognition.stop();
            } else {
                voiceRecognition.start();
            }
        }

        function stopRecordingUI() {
            isRecording = false;
            const btn = document.getElementById('btn-record-voice');
            const pulse = document.getElementById('voice-pulse');
            const statusText = document.getElementById('ai-status-text');
            
            if (btn) btn.style.background = ''; // Eski rengine dön (kırmızı)
            if (pulse) pulse.style.display = 'none';
            if (statusText && statusText.innerHTML === '🎙️ Dinleniyor... Konuşun...') {
                statusText.innerHTML = 'Mikrofonu kullanmak için butona tıklayıp konuşun veya doğrudan metin alanına yazın.';
            }
        }

        async function applyAIUpdate() {
            const input = document.getElementById('ai-command-input');
            const btnApply = document.getElementById('btn-apply-ai');
            const btnRecord = document.getElementById('btn-record-voice');
            const statusText = document.getElementById('ai-status-text');
            const reportBox = document.getElementById('ai-report-box');
            const reportList = document.getElementById('ai-report-list');

            const command = input.value.trim();
            if (!command) {
                alert("Lütfen önce bir ses kaydı alın veya güncelleme komutunu yazın.");
                return;
            }

            btnApply.disabled = true;
            btnRecord.disabled = true;
            statusText.innerHTML = '✨ Yapay zeka komutunuzu analiz ediyor, lütfen bekleyin...';
            reportBox.style.display = 'none';
            reportList.innerHTML = '';

            const datePicker = document.getElementById('classroom-date-picker');
            const dateStr = datePicker ? datePicker.value : '';

            try {
                const response = await fetch('/Teacher/AIUpdateClassroom', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({
                        classroomId: '@classroom?.Id',
                        command: command,
                        dateStr: dateStr
                    })
                });

                const data = await response.json();
                if (data.success && data.result && data.result.success) {
                    const result = data.result;
                    statusText.innerHTML = '✅ Güncellemeler başarıyla uygulandı! Sayfa yenileniyor...';
                    
                    if (result.updatedStudents && result.updatedStudents.length > 0) {
                        reportBox.style.display = 'block';
                        result.updatedStudents.forEach(rep => {
                            const li = document.createElement('li');
                            li.innerHTML = rep;
                            reportList.appendChild(li);
                        });
                    }

                    setTimeout(() => {
                        window.location.reload();
                    }, 3500);
                } else {
                    const errMsg = data.message || (data.result ? data.result.message : 'Bilinmeyen hata');
                    statusText.innerHTML = '❌ Hata oluştu: ' + errMsg;
                    btnApply.disabled = false;
                    btnRecord.disabled = false;
                }
            } catch (err) {
                console.error(err);
                statusText.innerHTML = '❌ Sunucuyla iletişim kurulurken bir hata oluştu.';
                btnApply.disabled = false;
                btnRecord.disabled = false;
            }
        }
    </script>
}

