        async function saveNewMedication() {
            const studentId = document.getElementById('medStudentId').value;
            const name = document.getElementById('medName').value.trim();
            const dosage = document.getElementById('medDosage').value.trim();
            const time = document.getElementById('medTime').value;
            const note = document.getElementById('medNote').value.trim();

            if (!name || !dosage || !time) {
                alert("Lütfen ilaç adı, dozajı ve veriliş saatini giriniz.");
                return;
            }

            try {
                const res = await fetch('/Teacher/AddMedicationRecord', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({
                        studentId: studentId,
                        medicineName: name,
                        dosage: dosage,
                        administrationTime: time,
                        taken: false,
                        note: note || null
                    })
                });
                const data = await res.json();
                if (data.success) {
                    window.location.reload();
                } else {
                    alert("İlaç kaydedilirken hata oluştu: " + data.message);
                }
            } catch (err) {
                console.error(err);
                alert("İletişim hatası.");
            }
        }

        async function toggleMedicationTaken(id, studentId, medicineName, dosage, time, note) {
            const chk = document.getElementById('chk-med-' + id);
            const taken = chk.checked;

            try {
                const res = await fetch('/Teacher/UpdateMedicationRecord', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({
                        id: id,
                        medicineName: medicineName,
                        dosage: dosage,
                        administrationTime: time,
                        taken: taken,
                        note: note || null
                    })
                });
                const data = await res.json();
                if (!data.success) {
                    alert("İlaç durumu güncellenirken hata oluştu: " + data.message);
                    chk.checked = !taken; // geri al
                } else {
                    // Kutunun yanındaki yazının rengini güncelle
                    const label = chk.closest('label');
                    if (label) {
                        label.style.color = taken ? '#059669' : 'var(--text-secondary)';
                    }
                }
            } catch (err) {
                console.error(err);
                alert("İletişim hatası.");
                chk.checked = !taken;
            }
        }

        async function deleteMedication(id) {
            if (!confirm("Bu ilaç kaydını silmek istediğinize emin misiniz?")) return;

            try {
                const res = await fetch(`/Teacher/DeleteMedicationRecord?id=${id}`, {
                    method: 'POST'
                });
                const data = await res.json();
                if (data.success) {
                    const row = document.getElementById('med-row-' + id);
                    if (row) {
                        const parent = row.parentElement;
                        row.remove();
                        if (parent && parent.children.length === 0) {
                            parent.innerHTML = '<span class="no-meds-label" style="font-size: 0.85rem; color: var(--text-muted); font-style: italic;">Bugün için ilaç kaydı bulunmuyor.</span>';
                            const tr = parent.closest('tr');
                            if (tr) {
                                tr.setAttribute('data-has-meds', 'false');
                                const filterCheckbox = document.getElementById('filter-meds-only');
