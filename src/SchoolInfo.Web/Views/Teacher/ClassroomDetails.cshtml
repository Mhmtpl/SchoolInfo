            </div>

            <div id="newsletterSectionsContainer">
                <!-- Dinamik Bölümler Buraya Gelecek -->
            </div>

            <div style="display: flex; gap: 1rem; margin-top: 2rem;">
                <button type="button" onclick="closeNewsletterModal()" class="btn-secondary" style="flex: 1;">İptal</button>
                <button type="submit" class="btn-primary" style="flex: 1; margin-top: 0;">Taslak Olarak Kaydet</button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <script>
        const classroomId = '@classroom?.Id';

        // Modern Tab Navigation
        function switchMainTab(tabId, btnElement) {
            // Remove active class from all buttons and contents
            document.querySelectorAll('.modern-tab-btn').forEach(btn => btn.classList.remove('active'));
            document.querySelectorAll('.modern-tab-content').forEach(content => content.classList.remove('active'));
            
            // Add active class to clicked button and target content
            if (btnElement) {
                btnElement.classList.add('active');
            } else {
                const btn = document.querySelector(`.modern-tab-btn[onclick*="${tabId}"]`);
                if (btn) btn.classList.add('active');
            }
            document.getElementById(tabId).classList.add('active');
            
            // Save active tab
            localStorage.setItem('activeClassroomTab', tabId);
        }

        // Restore active tab on page load
        document.addEventListener('DOMContentLoaded', () => {
            const savedTab = localStorage.getItem('activeClassroomTab');
            if (savedTab && document.getElementById(savedTab)) {
                switchMainTab(savedTab, null);
            }
        });
        
        // Haftalık Ders Programı Sekmeleri
        function selectScheduleDay(dayId) {
            // Buton sınıflarını sıfırla
            document.querySelectorAll('.schedule-tab-btn').forEach(btn => {
                btn.classList.remove('active');
            });
            // Seçili butona active sınıfı ekle
            document.getElementById('btn-schedule-day-' + dayId).classList.add('active');

            // Tüm içerikleri gizle
            for(let i=1; i<=5; i++) {
                const el = document.getElementById('schedule-content-day-' + i);
                if (el) el.style.display = 'none';
            }
            // Seçili içeriği göster
            const targetEl = document.getElementById('schedule-content-day-' + dayId);
            if (targetEl) targetEl.style.display = 'block';
        }

        // Modal Kontrolleri
        function openModal() {
            document.getElementById('activityModal').style.display = 'flex';
        }
        function closeModal() {
            document.getElementById('activityModal').style.display = 'none';
        }
        function openNewsletterModal() {
            document.getElementById('newsletterModalTitle').innerText = "Yeni Bülten Oluştur";
            document.getElementById('newsletterForm').action = "/Newsletter/CreateNewsletter";
            document.getElementById('newsletterId').value = "";
            document.getElementById('newsletterTitle').value = "";
            document.getElementById('newsletterWeekName').value = "";
            document.getElementById('imageUrl').value = "";
            document.getElementById('newsletterContent').value = "";
            document.getElementById('newsletterSectionsContainer').innerHTML = "";
            sectionIndex = 0;
            document.getElementById('newsletterModal').style.display = 'flex';
        }
        function closeNewsletterModal() {
            document.getElementById('newsletterModal').style.display = 'none';
        }
        
        function openEditNewsletterModal(newsletter) {
            document.getElementById('newsletterModalTitle').innerText = "Bülteni Düzenle";
            document.getElementById('newsletterForm').action = "/Newsletter/UpdateNewsletter";
            document.getElementById('newsletterId').value = newsletter.id;
            document.getElementById('newsletterTitle').value = newsletter.title || "";
            document.getElementById('newsletterWeekName').value = newsletter.weekName || "";
            document.getElementById('imageUrl').value = newsletter.imageUrl || "";
            document.getElementById('newsletterContent').value = newsletter.content || "";
            
            document.getElementById('newsletterSectionsContainer').innerHTML = "";
            sectionIndex = 0;
            
            if (newsletter.sections && newsletter.sections.length > 0) {
                newsletter.sections.forEach(sec => {
                    addNewsletterSectionWithValues(sec);
                });
            }
            
            document.getElementById('newsletterModal').style.display = 'flex';
        }

        let sectionIndex = 0;
        function addNewsletterSectionWithValues(sec) {
            const container = document.getElementById('newsletterSectionsContainer');
            const sectionHtml = `
                <div class="newsletter-section-item" style="border: 1px dashed var(--border-color); padding: 1rem; border-radius: 8px; margin-bottom: 1rem; position: relative;">
                    <button type="button" onclick="removeNewsletterSection(this)" style="position: absolute; right: 0.5rem; top: 0.5rem; background: none; border: none; color: #dc2626; cursor: pointer; font-size: 1.2rem;">&times;</button>
                    
                    <div class="form-group" style="margin-bottom: 0.8rem;">
                        <label>Konu / Ders (Örn: Fen ve Doğa)</label>
                        <input type="text" name="Sections[${sectionIndex}].Subject" class="form-control" value="${sec ? (sec.subject || '') : ''}" required />
                    </div>
                    
                    <div class="form-group" style="margin-bottom: 0.8rem;">
                        <label>Bu Hafta Neler Yaptık?</label>
                        <textarea name="Sections[${sectionIndex}].ThisWeekSummary" class="form-control" style="height: 60px; resize: none;" required>${sec ? (sec.thisWeekSummary || '') : ''}</textarea>
                    </div>
                    
                    <div class="form-group" style="margin-bottom: 0;">
                        <label>Gelecek Haftanın Konusu</label>
                        <input type="text" name="Sections[${sectionIndex}].NextWeekTopic" class="form-control" value="${sec ? (sec.nextWeekTopic || '') : ''}" required />
