        // Sütun başlığındaki dropdown ile tüm aktif öğrencilerin o öğün dropdownunu günceller
        function bulkMealUpdate(mealSlug, value) {
            if (value === '' || value === null || value === undefined) return;
            document.querySelectorAll(`[id^="meal-status-"][id$="-${mealSlug}"]`).forEach(sel => {
                if (!sel.disabled) {
                    const ph = sel.querySelector('option[value=""]');
                    if (ph) ph.remove();
                    sel.value = parseInt(value);
                }
            });
        }

        // Tüm öğrencilerin tüm öğün kaydet işlemlerini sırayla tetikler
        async function saveAllMeals() {
            const rows = document.querySelectorAll('[id^="meal-row-tr-"]');
            let successCount = 0;
            let skipCount = 0;
            let errorCount = 0;

            const saveBtn = document.querySelector('[onclick="saveAllMeals()"]');
            if (saveBtn) { saveBtn.disabled = true; saveBtn.innerHTML = '⏳ Kaydediliyor...'; }

            for (const row of rows) {
                if (row.style.opacity === '0.7') continue;
                const rowId = row.id.replace('meal-row-tr-', '');
                const slugs = ['breakfast', 'lunch', 'snack'];
                const mealNames = { breakfast: 'Kahvaltı', lunch: 'Öğle Yemeği', snack: 'İkindi Kahvaltısı' };

                for (const slug of slugs) {
                    const sel = document.getElementById(`meal-status-${rowId}-${slug}`);
                    if (!sel || sel.disabled || sel.value === '') { skipCount++; continue; }
                    const btn = document.getElementById(`btn-save-${rowId}-${slug}`);
                    if (!btn) { skipCount++; continue; }
                    const onclickStr = btn.getAttribute('onclick') || '';
                    const match = onclickStr.match(/saveIndividualMeal\('([^']+)',\s*'([^']+)',\s*'([^']+)',\s*'([^']+)'\)/);
                    if (!match) { skipCount++; continue; }
                    const [, sId, mealRecordId, mealName] = match;
                    const note = document.getElementById(`meal-note-${rowId}-${slug}`)?.value || '';
                    try {
                        const response = await fetch('/Teacher/UpdateMealRecord', {
                            method: 'POST',
                            headers: { 'Content-Type': 'application/json' },
                            body: JSON.stringify({ studentId: sId, mealRecordId, mealName, statusType: parseInt(sel.value), statusDescription: note })
                        });
                        const data = await response.json();
                        if (data.success) { successCount++; const ph = sel.querySelector('option[value=""]'); if (ph) ph.remove(); }
                        else { errorCount++; }
                    } catch { errorCount++; }
                }
            }

            if (saveBtn) {
                saveBtn.disabled = false;
                if (errorCount > 0) {
                    saveBtn.innerHTML = `❌ ${errorCount} Hata`;
                    saveBtn.style.background = '#ef4444';
                    setTimeout(() => { saveBtn.innerHTML = '💾 Tümünü Kaydet'; saveBtn.style.background = ''; }, 3000);
                    alert(`Toplu kayıt: ✅ ${successCount} başarılı, ❌ ${errorCount} hata, ⏭ ${skipCount} atlandı.`);
                } else {
                    saveBtn.innerHTML = `✓ ${successCount} Kayıt Tamamlandı!`;
                    saveBtn.style.background = '#059669';
                    setTimeout(() => { saveBtn.innerHTML = '💾 Tümünü Kaydet'; saveBtn.style.background = ''; }, 2500);
                }
            }
        }

        function changeClassroomDate(val) {
