                    <option value="Serbest Zaman">Serbest Zaman</option>
                    <option value="Kahvaltı">Kahvaltı</option>
                    <option value="Öğle Yemeği">Öğle Yemeği</option>
                    <option value="İkindi Kahvaltısı">İkindi Kahvaltısı</option>
