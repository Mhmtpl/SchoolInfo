            <div class="section-card-header" style="margin-top: 1.5rem; margin-bottom: 1rem; border-top: 1px solid var(--border-color); padding-top: 1rem;">
                <h3 style="font-size: 1.1rem;">Bülten Konuları (Aktivite Raporları)</h3>
