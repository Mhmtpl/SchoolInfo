@model List<SchoolInfo.Web.Models.ClassroomStudentDto>
@{
    ViewData["Title"] = "Veli Paneli";
}

<div class="teacher-workspace">
    <div>
        <h1 class="dashboard-title">Veli Paneli</h1>
        <p class="dashboard-desc">Çocuğunuzun günlük gelişim durumunu, yemek kayıtlarını, sınıf aktivitelerini ve yapay zeka özetlerini inceleyebilirsiniz.</p>
    </div>

    @if (ViewBag.ErrorMessage != null)
    {
        <div class="error-summary">@ViewBag.ErrorMessage</div>
    }

    <div class="glass-card">
        <div class="section-card-header">
            <h2>Kayıtlı Çocuklarınız (@Model.Count)</h2>
        </div>

        @if (Model.Count == 0)
        {
            <p style="color: var(--text-secondary); text-align: center; padding: 2rem;">Sisteme kayıtlı herhangi bir çocuğunuz bulunamadı.</p>
        }
        else
        {
            <div class="classrooms-grid">
                @foreach (var child in Model)
                {
                    <div class="glass-card class-card" style="padding: 1.5rem; border-color: rgba(16, 185, 129, 0.15);">
                        <div>
                            <span style="font-size: 0.75rem; color: var(--text-muted); text-transform: uppercase; font-weight: 600; letter-spacing: 0.05em;">Öğrenci Profili</span>
                            <h3 style="margin-top: 0.25rem;">@child.FirstName @child.LastName</h3>
                        </div>
                        <div class="class-card-action">
                            <span style="font-size: 0.85rem; color: var(--accent-green); font-weight: 500;">Okulda</span>
                            <a asp-controller="Parent" asp-action="ChildDetails" asp-route-id="@child.Id" class="card-link" style="color: var(--accent-green);">
                                Gelişim Kartı &rarr;
                            </a>
                        </div>
                    </div>
                }
            </div>
        }
    </div>
</div>
