@model List<SchoolInfo.Web.Models.ClassroomStudentDto>
@{
    ViewData["Title"] = "Veli Paneli";
}

<div class="teacher-workspace">
    
    @if (ViewBag.ErrorMessage != null)
    {
        <div class="error-summary">@ViewBag.ErrorMessage</div>
    }

    <!-- VELİ KARŞILAMA KARTI -->
    <div class="child-hero-card" style="margin-bottom: 2rem; background: linear-gradient(135deg, rgba(2, 132, 199, 0.1) 0%, rgba(139, 92, 246, 0.1) 100%);">
        <div style="display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: 1.5rem;">
            <div style="display: flex; align-items: center; gap: 1.5rem;">
                <div style="width: 70px; height: 70px; background: linear-gradient(135deg, #0ea5e9 0%, #6366f1 100%); border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 1.8rem; box-shadow: 0 8px 20px rgba(14, 165, 233, 0.3);">
                    👋
                </div>
                <div class="child-hero-info">
                    <h1>Hoş Geldiniz, Veli</h1>
                    <div class="child-hero-meta">
                        <span>Çocuğunuzun eğitim yolculuğu bir tık uzağınızda.</span>
                    </div>
                </div>
            </div>
            <div class="child-hero-date" style="background: rgba(255,255,255,0.7); color: var(--text-primary);">
                📅 @DateTime.UtcNow.ToLocalTime().ToString("dd MMMM yyyy, dddd")
            </div>
        </div>
    </div>

    <div class="glass-card">
        <div class="section-card-header" style="border-bottom: 1px solid var(--border-color); padding-bottom: 1rem; margin-bottom: 1.5rem;">
            <h2 style="font-size: 1.3rem; display: flex; align-items: center; gap: 0.5rem;">
                👶 Kayıtlı Çocuklarınız 
                <span style="background: var(--accent-blue); color: white; padding: 0.1rem 0.5rem; border-radius: 20px; font-size: 0.8rem;">@Model.Count</span>
            </h2>
        </div>

        @if (Model.Count == 0)
        {
            <div style="padding: 3rem 1rem; text-align: center; color: var(--text-secondary);">
                <div style="font-size: 3rem; margin-bottom: 1rem; opacity: 0.5;">📭</div>
                <p>Sisteme kayıtlı herhangi bir çocuğunuz bulunamadı.</p>
                <p style="font-size: 0.85rem; margin-top: 0.5rem;">Lütfen okul yönetimi ile iletişime geçerek çocuğunuzun hesabınıza tanımlanmasını talep ediniz.</p>
            </div>
        }
        else
        {
            <div class="classrooms-grid">
                @foreach (var child in Model)
                {
                    <a asp-controller="Parent" asp-action="ChildDetails" asp-route-id="@child.Id" style="text-decoration: none; color: inherit; display: block;">
                        <div class="glass-card class-card hover-lift" style="padding: 1.5rem; border: 1px solid rgba(139, 92, 246, 0.2); position: relative; overflow: hidden; display: flex; flex-direction: column; justify-content: space-between; min-height: 180px;">
                            <!-- Dekoratif Arka Plan Parıltısı -->
                            <div style="position: absolute; top: -50px; right: -50px; width: 100px; height: 100px; background: rgba(139, 92, 246, 0.1); border-radius: 50%; filter: blur(20px);"></div>
                            
                            <div style="position: relative; z-index: 1;">
                                <div style="display: flex; align-items: center; gap: 1rem; margin-bottom: 1rem;">
                                    <div style="width: 50px; height: 50px; background: rgba(139, 92, 246, 0.1); border-radius: 12px; display: flex; align-items: center; justify-content: center; font-size: 1.5rem; color: #8b5cf6;">
                                        @{
                                            string initials = "";
                                            var parts = child.FirstName.Split(' ', StringSplitOptions.RemoveEmptyEntries);
                                            if(parts.Length > 0) initials += parts[0][0];
                                            if(!string.IsNullOrEmpty(child.LastName)) initials += child.LastName[0];
                                        }
                                        @initials
                                    </div>
                                    <div>
                                        <h3 style="margin: 0; font-size: 1.15rem; color: var(--text-primary);">@child.FirstName @child.LastName</h3>
                                        <span style="font-size: 0.75rem; color: var(--accent-green); font-weight: 600; display: inline-flex; align-items: center; gap: 0.25rem; margin-top: 0.25rem;">
                                            <span style="width: 6px; height: 6px; background: var(--accent-green); border-radius: 50%; display: inline-block;"></span>
                                            Okulda Aktif
                                        </span>
                                    </div>
                                </div>
                                <p style="font-size: 0.85rem; color: var(--text-secondary); line-height: 1.5; margin-bottom: 0;">
                                    Çocuğunuzun bugünkü yapay zeka özetini, beslenme raporlarını ve uyku düzenini incelemek için tıklayın.
                                </p>
                            </div>

                            <div style="position: relative; z-index: 1; margin-top: 1.5rem; border-top: 1px solid var(--border-color); padding-top: 1rem;">
                                <span class="btn-primary" style="text-align: center; display: block; background: linear-gradient(135deg, #8b5cf6 0%, #6366f1 100%); border: none; padding: 0.5rem; border-radius: 6px; color: white;">
                                    📊 Gelişim Kartını İncele &rarr;
                                </span>
                            </div>
                        </div>
                    </a>
                }
            </div>
        }
    </div>
</div>

<style>
    .hover-lift {
        transition: transform 0.3s ease, box-shadow 0.3s ease;
    }
    .hover-lift:hover {
        transform: translateY(-5px);
        box-shadow: 0 15px 30px rgba(139, 92, 246, 0.15);
    }
</style>
