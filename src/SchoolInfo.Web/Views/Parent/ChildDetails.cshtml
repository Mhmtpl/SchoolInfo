@using SchoolInfo.Web.Models
@{
    var dailyRecord = ViewBag.DailyRecord as ClassroomDailyRecordDto;
    var mealRecord = ViewBag.MealRecord as StudentMealDto;
    var activities = ViewBag.Activities as List<ActivityDto> ?? new List<ActivityDto>();
    var newsletters = ViewBag.Newsletters as List<NewsletterDto> ?? new List<NewsletterDto>();
    var aiSummary = ViewBag.AiSummary as string;
    
    ViewData["Title"] = $"{ViewBag.StudentName} Gelişim Kartı";

    // Beslenme Hesaplamaları
    var detailedMeals = ViewBag.DetailedMeals as StudentDetailedMealsResponse;
    var breakfast = detailedMeals?.Meals?.FirstOrDefault(m => m.MealName.Contains("Kahvaltı", StringComparison.OrdinalIgnoreCase) && !m.MealName.Contains("İkindi", StringComparison.OrdinalIgnoreCase));
    var lunch = detailedMeals?.Meals?.FirstOrDefault(m => m.MealName.Contains("Öğle", StringComparison.OrdinalIgnoreCase));
    var snack = detailedMeals?.Meals?.FirstOrDefault(m => m.MealName.Contains("İkindi", StringComparison.OrdinalIgnoreCase));

    int totalPlannedCalories = 0;
    double totalConsumedCalories = 0;
    double totalPlannedProtein = 0;
    double totalConsumedProtein = 0;
    double totalPlannedCarbs = 0;
    double totalConsumedCarbs = 0;

    if (breakfast != null)
    {
        var cal = breakfast.PlannedCalories ?? 0;
        var prot = breakfast.ProteinGrams ?? 0;
        var carb = breakfast.CarbsGrams ?? 0;

        totalPlannedCalories += cal;
        totalPlannedProtein += prot;
        totalPlannedCarbs += carb;

        double ratio = breakfast.StatusType switch
        {
            3 => 1.0,
            2 => 0.5,
            1 => 0.25,
            _ => 0.0
        };
        totalConsumedCalories += cal * ratio;
        totalConsumedProtein += prot * ratio;
        totalConsumedCarbs += carb * ratio;
    }

    if (lunch != null)
    {
        var cal = lunch.PlannedCalories ?? 0;
        var prot = lunch.ProteinGrams ?? 0;
        var carb = lunch.CarbsGrams ?? 0;

        totalPlannedCalories += cal;
        totalPlannedProtein += prot;
        totalPlannedCarbs += carb;

        double ratio = lunch.StatusType switch
        {
            3 => 1.0,
            2 => 0.5,
            1 => 0.25,
            _ => 0.0
        };
        totalConsumedCalories += cal * ratio;
        totalConsumedProtein += prot * ratio;
        totalConsumedCarbs += carb * ratio;
    }

    if (snack != null)
    {
        var cal = snack.PlannedCalories ?? 0;
        var prot = snack.ProteinGrams ?? 0;
        var carb = snack.CarbsGrams ?? 0;

        totalPlannedCalories += cal;
        totalPlannedProtein += prot;
        totalPlannedCarbs += carb;

        double ratio = snack.StatusType switch
        {
            3 => 1.0,
            2 => 0.5,
            1 => 0.25,
            _ => 0.0
        };
        totalConsumedCalories += cal * ratio;
        totalConsumedProtein += prot * ratio;
        totalConsumedCarbs += carb * ratio;
    }

    int caloriePercentage = totalPlannedCalories > 0 ? (int)Math.Round((totalConsumedCalories / totalPlannedCalories) * 100) : 0;
    int waterIntake = dailyRecord?.WaterIntake ?? 0;
    int waterPercentage = Math.Min(100, (int)Math.Round((waterIntake / 2000.0) * 100));
}

<!-- Chart.js CDN inclusion -->
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

<!-- html2pdf.js for PDF export -->
<script src="https://cdnjs.cloudflare.com/ajax/libs/html2pdf.js/0.10.1/html2pdf.bundle.min.js"></script>

<div class="teacher-workspace">
    <!-- Geri Dönüş Linki -->
    <div style="margin-bottom: 0.5rem;">
        <a asp-action="Index" style="font-size: 0.9rem; color: var(--text-muted); display: inline-flex; align-items: center; gap: 0.35rem; font-weight: 500;">
            &larr; Çocuklarıma Geri Dön
        </a>
    </div>

    @if (ViewBag.ErrorMessage != null)
    {
        <div class="error-summary">@ViewBag.ErrorMessage</div>
    }

    <!-- ÇOCUK KAHRAMAN KARTI (Child Hero Card) -->
    <div class="child-hero-card">
        <div style="display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: 1.5rem; width: 100%;">
            <!-- Profil Baş Harfleri Avatarı -->
            <div style="width: 70px; height: 70px; background: linear-gradient(135deg, var(--accent-blue) 0%, var(--accent-purple) 100%); border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 1.6rem; font-weight: 800; color: white; border: 3px solid rgba(255,255,255,0.15); box-shadow: 0 8px 20px rgba(2, 132, 199, 0.25);">
                @{
                    string initials = "";
                    string fullName = ViewBag.StudentName as string ?? "";
                    var parts = fullName.Split(' ', StringSplitOptions.RemoveEmptyEntries);
                    if (parts.Length > 0) initials += parts[0][0];
                    if (parts.Length > 1) initials += parts[parts.Length - 1][0];
                }
                @initials
            </div>
            <div class="child-hero-info">
                <h1>@ViewBag.StudentName</h1>
                <div class="child-hero-meta">
                    <span>Sınıf: <strong>@ViewBag.ClassroomName</strong></span>
                    <span style="opacity: 0.5;">|</span>
                    <span class="child-hero-badge">Öğrenci Kartı</span>
                </div>
            </div>
        <div class="child-hero-date" style="display: flex; align-items: center; gap: 0.5rem; background: rgba(255,255,255,0.1); padding: 0.4rem 0.8rem; border-radius: 8px; color: white;">
            <span>Tarih:</span>
            <input type="date" id="child-date-picker" value="@ViewBag.SelectedDate" 
                   min="@DateTime.UtcNow.AddHours(3).Date.AddDays(-2).ToString("yyyy-MM-dd")" 
                   max="@DateTime.UtcNow.AddHours(3).Date.ToString("yyyy-MM-dd")" 
                   style="padding: 0.25rem 0.5rem; border-radius: 6px; border: 1px solid rgba(255,255,255,0.2); font-family: inherit; font-size: 0.9rem; font-weight: 600; color: #1e293b; background: white; cursor: pointer;"
                   onchange="changeChildDate(this.value)" />
        </div>
    </div>

    @if (dailyRecord != null && dailyRecord.IsAbsent)
    {
        <div class="warning-summary" style="background: #fee2e2; border: 1px solid #fca5a5; color: #b91c1c; padding: 1.2rem; border-radius: 12px; margin-bottom: 1.5rem; font-weight: 700; font-size: 1.1rem; display: flex; align-items: center; gap: 0.75rem; box-shadow: 0 4px 15px rgba(220, 38, 38, 0.08);">
            <span>🚨</span>
            Öğrenci bu tarihte devamsızdır.
        </div>
    }

    <!-- İKİ KOLONLU PANORAMİK DÜZEN -->
    <div class="parent-dashboard">
        <!-- SOL KOLON: GÜNLÜK HİKAYE VE SAĞLIK VERİLERİ -->
        <div class="child-main-panel">
            
            <!-- AI GÜNLÜK ÖZETİ (Günün Hikayesi) -->
            <div class="ai-story-card-premium">
                <div class="ai-story-title">
                    <span>✨ Günün Hikayesi</span>
                </div>
                <div class="ai-story-text">
                    @aiSummary
                </div>
            </div>

            <!-- SAĞLIK GÖSTERGELERİ (Su Tüketimi & Uyku Düzeni) -->
            <div style="display: grid; grid-template-columns: 1fr; gap: 1.5rem;">
                <!-- Su Tüketimi (Görsel Su Bardağı) ve Uyku Kartı Grid -->
                <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 1.5rem;">
                    
                    <!-- SU TÜKETİMİ -->
                    <div class="glass-card" style="display: flex; align-items: center; gap: 2rem; padding: 1.8rem;">
                        <div class="water-tracker">
                            <div class="water-glass-container">
                                <div class="water-glass-water" style="height: @(waterPercentage)%;"></div>
                            </div>
                            <span class="water-amount-badge">@waterIntake ml</span>
                        </div>
                        <div style="flex: 1;">
                            <h3 style="font-size: 1.25rem; font-weight: 700; margin-bottom: 0.5rem; color: var(--text-primary);">💧 Hidrasyon Durumu</h3>
                            <p style="font-size: 0.88rem; color: var(--text-secondary); line-height: 1.5;">
                                Çocuğunuz bugün günlük <strong>2000 ml</strong> su hedefinin <strong>%@waterPercentage</strong> kadarını tüketti.
                            </p>
                        </div>
                    </div>

                    <!-- UYKU DÜZENİ -->
                    <div class="sleep-card-premium">
                        <div>
                            <span style="font-size: 2.2rem;">🌙</span>
                            <h3 style="font-size: 1.25rem; font-weight: 700; margin-top: 0.5rem; margin-bottom: 0.25rem;">Uyku Karnesi</h3>
                            <p style="font-size: 0.88rem; color: #cbd5e1; line-height: 1.5; margin-bottom: 0.5rem;">
                                Öğle uykusu ve dinlenme durumu.
                            </p>
                            @{
                                var sleepLabel = dailyRecord?.SleepStatus switch
                                {
                                    2 => "Çok İyi Uyudu",
                                    1 => "Az Uyudu",
                                    0 => "Hiç Uyumadı",
                                    _ => "Giriş Yapılmadı"
                                };
                            }
                            <span class="sleep-status-badge">@sleepLabel</span>
                        </div>
                    </div>

                </div>
            </div>

            <!-- İLAÇ TAKİBİ -->
            @{
                var medicationRecords = ViewBag.MedicationRecords as List<MedicationRecordDto> ?? new List<MedicationRecordDto>();
            }
            <div class="glass-card" style="padding: 2rem; margin-top: 1.5rem; margin-bottom: 1.5rem;">
                <div class="section-card-header" style="display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 1rem; margin-bottom: 1.5rem;">
                    <h2 style="font-size: 1.4rem; font-weight: 700; color: var(--text-primary); margin-bottom: 0; display: flex; align-items: center; gap: 0.5rem;">
                        💊 Bugünkü İlaç Takip Durumu
                    </h2>
                    <button type="button" onclick="openParentMedicationModal()" class="btn-secondary" style="margin-top: 0; padding: 0.4rem 0.8rem; font-size: 0.85rem; display: inline-flex; align-items: center; gap: 0.25rem;">
                        ➕ İlaç Ekle
                    </button>
                </div>
                @if (!medicationRecords.Any())
                {
                    <div style="background: rgba(0,0,0,0.01); border: 1px dashed var(--border-color); border-radius: 12px; padding: 1.5rem; text-align: center; color: var(--text-secondary); font-size: 0.9rem; font-style: italic;">
                        Bugün verilmesi planlanan bir ilaç bulunmuyor.
                    </div>
                }
                else
                {
                    <div style="display: flex; flex-direction: column; gap: 0.8rem;">
                        @foreach (var med in medicationRecords)
                        {
                            <div id="parent-med-row-@med.Id" style="display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 1rem; background: rgba(30, 60, 114, 0.03); border: 1px solid rgba(30, 60, 114, 0.08); padding: 1rem 1.25rem; border-radius: 12px;">
                                <div>
                                    <span style="font-weight: 700; color: #1e3c72; font-size: 1.05rem;">💊 @med.MedicineName</span>
                                    <span style="font-size: 0.85rem; color: var(--text-secondary); margin-left: 0.4rem;">(@med.Dosage)</span>
                                    <div style="font-size: 0.8rem; color: var(--text-muted); margin-top: 0.3rem; display: flex; gap: 0.8rem; align-items: center; flex-wrap: wrap;">
                                        <span style="background: #e0f2fe; color: #0369a1; padding: 0.1rem 0.4rem; border-radius: 4px; font-weight: 600;">⏰ Veriliş Saati: @med.AdministrationTime</span>
                                        @if (!string.IsNullOrEmpty(med.Note))
                                        {
                                            <span>• <strong>Not:</strong> @med.Note</span>
                                        }
                                    </div>
                                </div>
                                <div style="display: flex; align-items: center; gap: 0.75rem;">
                                    @if (med.Taken)
                                    {
                                        <span style="font-size: 0.82rem; color: #065f46; background: #d1fae5; border: 1px solid #a7f3d0; padding: 0.3rem 0.8rem; border-radius: 20px; font-weight: 700; display: inline-flex; align-items: center; gap: 0.25rem;">
                                            ✓ İlaç Verildi
                                        </span>
                                    }
                                    else
                                    {
                                        <span style="font-size: 0.82rem; color: #7c2d12; background: #ffedd5; border: 1px solid #fed7aa; padding: 0.3rem 0.8rem; border-radius: 20px; font-weight: 700; display: inline-flex; align-items: center; gap: 0.25rem;">
                                            • Beklemede
                                        </span>
                                        <button type="button" onclick="deleteParentMedication('@med.Id')" style="background: none; border: none; color: #ef4444; cursor: pointer; font-size: 1.1rem; line-height: 1; padding: 0.2rem;" title="Sil">🗑️</button>
                                    }
                                </div>
                            </div>
                        }
                    </div>
                }
            </div>

            <!-- BESLENME VE ENERJİ ANALİZİ -->
            <div class="glass-card" style="padding: 2rem;">
                <h2 style="font-size: 1.4rem; font-weight: 700; color: var(--text-primary); margin-bottom: 1.5rem; display: flex; align-items: center; gap: 0.5rem;">
                    🍳 Beslenme & Enerji Karnesi
                </h2>

                <!-- Grafik Alanı (Chart.js) -->
                @if (totalPlannedCalories > 0)
                {
                    <div class="chart-container-premium">
                        <canvas id="nutritionChart" style="max-height: 250px; width: 100%;"></canvas>
                    </div>
                }
                else
                {
                    <div style="background: rgba(0,0,0,0.01); border: 1px dashed var(--border-color); border-radius: 12px; padding: 1.5rem; text-align: center; color: var(--text-secondary); margin-bottom: 1.5rem; font-size: 0.9rem;">
                        Bugün için beslenme planı girilmemiştir.
                    </div>
                }

                <!-- Detaylı Öğün Tablosu -->
                <h3 style="font-size: 1.15rem; font-weight: 700; color: var(--text-primary); margin-top: 2rem; margin-bottom: 0.75rem;">📋 Detaylı Günlük Öğün Listesi</h3>
                
                <div class="premium-table-container">
                    <table class="premium-table">
                        <thead>
                            <tr>
                                <th>Öğün</th>
                                <th>Yemek İçeriği</th>
                                <th>Tüketim Durumu</th>
                                <th>Besin Değerleri</th>
                                <th>Açıklama</th>
                            </tr>
                        </thead>
                        <tbody>
                            <!-- KAHVALTI ROW -->
                            <tr>
                                <td style="font-weight: 700;">🍳 Kahvaltı</td>
                                <td style="font-size: 0.85rem; max-width: 200px;">
                                    @(breakfast != null && !string.IsNullOrEmpty(breakfast.FoodContent) ? breakfast.FoodContent : "Girilmedi")
                                </td>
                                <td>
                                    @if (breakfast != null && breakfast.MealRecordId != Guid.Empty)
                                    {
                                        var badgeClass = breakfast.StatusType switch
                                        {
                                            3 => "meal-badge-all",
                                            2 => "meal-badge-half",
                                            1 => "meal-badge-little",
                                            _ => "meal-badge-none"
                                        };
                                        var statusText = breakfast.StatusType switch
                                        {
                                            3 => "Hepsini Yedi",
                                            2 => "Yarısını Yedi",
                                            1 => "Az Yedi",
                                            _ => "Hiç Yemedi"
                                        };
                                        <span class="meal-badge @badgeClass">@statusText</span>
                                    }
                                    else
                                    {
                                        <span class="meal-badge" style="background: var(--border-color); color: var(--text-muted);">Girilmedi</span>
                                    }
                                </td>
                                <td style="font-size: 0.85rem; font-weight: 500;">
                                    @(breakfast != null ? $"{breakfast.PlannedCalories ?? 0} kcal | {breakfast.ProteinGrams ?? 0}g P | {breakfast.CarbsGrams ?? 0}g K" : "-")
                                </td>
                                <td style="font-size: 0.85rem; color: var(--text-secondary); font-style: italic;">
                                    @(breakfast != null && !string.IsNullOrEmpty(breakfast.StatusDescription) ? breakfast.StatusDescription : "-")
                                </td>
                            </tr>

                            <!-- ÖĞLE YEMEĞİ ROW -->
                            <tr>
                                <td style="font-weight: 700;">🍲 Öğle Yemeği</td>
                                <td style="font-size: 0.85rem; max-width: 200px;">
                                    @(lunch != null && !string.IsNullOrEmpty(lunch.FoodContent) ? lunch.FoodContent : "Girilmedi")
                                </td>
                                <td>
                                    @if (lunch != null && lunch.MealRecordId != Guid.Empty)
                                    {
                                        var badgeClass = lunch.StatusType switch
                                        {
                                            3 => "meal-badge-all",
                                            2 => "meal-badge-half",
                                            1 => "meal-badge-little",
                                            _ => "meal-badge-none"
                                        };
                                        var statusText = lunch.StatusType switch
                                        {
                                            3 => "Hepsini Yedi",
                                            2 => "Yarısını Yedi",
                                            1 => "Az Yedi",
                                            _ => "Hiç Yemedi"
                                        };
                                        <span class="meal-badge @badgeClass">@statusText</span>
                                    }
                                    else
                                    {
                                        <span class="meal-badge" style="background: var(--border-color); color: var(--text-muted);">Girilmedi</span>
                                    }
                                </td>
                                <td style="font-size: 0.85rem; font-weight: 500;">
                                    @(lunch != null ? $"{lunch.PlannedCalories ?? 0} kcal | {lunch.ProteinGrams ?? 0}g P | {lunch.CarbsGrams ?? 0}g K" : "-")
                                </td>
                                <td style="font-size: 0.85rem; color: var(--text-secondary); font-style: italic;">
                                    @(lunch != null && !string.IsNullOrEmpty(lunch.StatusDescription) ? lunch.StatusDescription : "-")
                                </td>
                            </tr>

                            <!-- İKİNDİ KAHVALTISI ROW -->
                            <tr>
                                <td style="font-weight: 700;">🧁 İkindi Kahvaltısı</td>
                                <td style="font-size: 0.85rem; max-width: 200px;">
                                    @(snack != null && !string.IsNullOrEmpty(snack.FoodContent) ? snack.FoodContent : "Girilmedi")
                                </td>
                                <td>
                                    @if (snack != null && snack.MealRecordId != Guid.Empty)
                                    {
                                        var badgeClass = snack.StatusType switch
                                        {
                                            3 => "meal-badge-all",
                                            2 => "meal-badge-half",
                                            1 => "meal-badge-little",
                                            _ => "meal-badge-none"
                                        };
                                        var statusText = snack.StatusType switch
                                        {
                                            3 => "Hepsini Yedi",
                                            2 => "Yarısını Yedi",
                                            1 => "Az Yedi",
                                            _ => "Hiç Yemedi"
                                        };
                                        <span class="meal-badge @badgeClass">@statusText</span>
                                    }
                                    else
                                    {
                                        <span class="meal-badge" style="background: var(--border-color); color: var(--text-muted);">Girilmedi</span>
                                    }
                                </td>
                                <td style="font-size: 0.85rem; font-weight: 500;">
                                    @(snack != null ? $"{snack.PlannedCalories ?? 0} kcal | {snack.ProteinGrams ?? 0}g P | {snack.CarbsGrams ?? 0}g K" : "-")
                                </td>
                                <td style="font-size: 0.85rem; color: var(--text-secondary); font-style: italic;">
                                    @(snack != null && !string.IsNullOrEmpty(snack.StatusDescription) ? snack.StatusDescription : "-")
                                </td>
                            </tr>
                        </tbody>
                    </table>
                </div>

                <!-- ÖĞRETMEN NOTU KONUŞMA BALONU -->
                @if (dailyRecord != null && !string.IsNullOrEmpty(dailyRecord.TeacherNotes))
                {
                    <div class="teacher-bubble-card">
                        <div class="teacher-bubble-title">
                            👩‍🏫 Öğretmenin Kaleminden Not
                        </div>
                        <div class="teacher-bubble-text">
                            "@dailyRecord.TeacherNotes"
                        </div>
                    </div>
                }
            </div>
        </div>

        <!-- SAĞ KOLON: AKTİVİTELER VE PROGRAM -->
        <div class="child-main-panel">
            <!-- MODERN TABS FOR PARENT PANELS -->
            <div class="modern-tabs">
                <button onclick="switchParentTab('tab-parent-activities')" id="btn-parent-activities" class="modern-tab-btn active">🎨 Bugünün Akışı</button>
                <button onclick="switchParentTab('tab-parent-weekly')" id="btn-parent-weekly" class="modern-tab-btn">📅 Haftalık Program</button>
                <button onclick="switchParentTab('tab-parent-newsletters')" id="btn-parent-newsletters" class="modern-tab-btn">📰 Sınıf Bültenleri</button>
            </div>

            <!-- TAB 1: BUGÜNÜN AKTİVİTELERİ -->
            <div id="tab-parent-activities" class="modern-tab-content active">
                <div class="glass-card" style="padding: 2rem;">
                    <h2 style="font-size: 1.4rem; font-weight: 700; color: var(--text-primary); margin-bottom: 1.5rem; display: flex; align-items: center; gap: 0.5rem;">
                        🎨 Bugünün Sınıf İçi Aktiviteleri
                    </h2>

                    @if (activities.Count == 0)
                    {
                        <p style="color: var(--text-secondary); text-align: center; padding: 2rem; font-size: 0.9rem; font-style: italic;">
                            Bugün henüz bir aktivite yapılmadı.
                        </p>
                    }
                    else
                    {
                        var currentTime = DateTime.UtcNow.ToLocalTime().TimeOfDay;
                        <div class="timeline">
                            @foreach (var activity in activities.OrderBy(a => a.StartTime))
                            {
                                bool isPast = activity.EndTime <= currentTime || activity.CompletedAt.HasValue;
                                bool isCurrent = !isPast && activity.StartTime <= currentTime && activity.EndTime > currentTime;
                                bool isFuture = !isPast && !isCurrent;

                                string dotClass = isPast ? "completed" : isCurrent ? "current" : "pending";
                                string dotIcon = isPast ? "✓" : isCurrent ? "▶" : "•";
                                string badgeClass = isPast ? "badge-completed" : isCurrent ? "badge-current" : "badge-pending";
                                string badgeText = isPast ? "Tamamlandı" : isCurrent ? "Şu An İşleniyor" : "Bekliyor";

                                <div class="timeline-item" style="opacity: @(isPast ? "0.7" : "1");">
                                    <div class="timeline-dot @dotClass">
                                        @dotIcon
                                    </div>
                                    <div class="timeline-content" style="@(isCurrent ? "border-left: 3px solid #059669; padding-left: 1rem; background: rgba(209, 250, 229, 0.3); border-radius: 4px;" : "")">
                                        <div class="timeline-title" style="font-size: 0.95rem; font-weight: 700; display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 0.5rem;">
                                            <span>@activity.StartTime.ToString(@"hh\:mm") - @activity.EndTime.ToString(@"hh\:mm") | @activity.Title</span>
                                            <span class="@badgeClass" style="@(isCurrent ? "background: #10b981; color: white; padding: 0.15rem 0.4rem; border-radius: 4px; font-size: 0.7rem; font-weight: 600;" : isPast ? "background: #d1fae5; color: #065f46; padding: 0.15rem 0.4rem; border-radius: 4px; font-size: 0.7rem; font-weight: 600;" : "background: #f3f4f6; color: #6b7280; padding: 0.15rem 0.4rem; border-radius: 4px; font-size: 0.7rem; font-weight: 600;")">@badgeText</span>
                                        </div>
                                        <div class="timeline-desc" style="font-size: 0.82rem; color: var(--text-secondary); margin-top: 0.25rem;">
                                            @activity.Description
                                        </div>
                                    </div>
                                </div>
                            }
                        </div>
                    }
                </div>
            </div>

            <!-- TAB 2: HAFTALIK PROGRAM -->
            <div id="tab-parent-weekly" class="modern-tab-content">
                <div class="glass-card" style="padding: 2rem;">
                    <h2 style="font-size: 1.4rem; font-weight: 700; color: var(--text-primary); margin-bottom: 1.5rem; display: flex; align-items: center; gap: 0.5rem;">
                        📅 Haftalık Sınıf Etkinlik Şablonu
                    </h2>
                    
                    @{
                        var weeklySchedule = ViewBag.WeeklySchedule as List<WeeklyScheduleDto> ?? new List<WeeklyScheduleDto>();
                    }

                    <!-- Gün Switcher'ı (Monday-Friday) -->
                    <div style="display: flex; gap: 0.35rem; justify-content: space-between; background: rgba(0,0,0,0.03); padding: 0.25rem; border-radius: 12px; border: 1px solid rgba(0,0,0,0.04); margin-bottom: 1.5rem;">
                        <button type="button" onclick="selectWeeklyScheduleDay(1)" id="btn-sch-day-1" class="day-select-btn active-day" style="flex: 1; padding: 0.5rem; border: none; border-radius: 9px; font-size: 0.8rem; font-weight: 700; cursor: pointer; transition: all 0.2s; background: #1e293b; color: white;">Pzt</button>
                        <button type="button" onclick="selectWeeklyScheduleDay(2)" id="btn-sch-day-2" class="day-select-btn" style="flex: 1; padding: 0.5rem; border: none; border-radius: 9px; font-size: 0.8rem; font-weight: 700; cursor: pointer; transition: all 0.2s; background: transparent; color: #4b5563;">Sal</button>
                        <button type="button" onclick="selectWeeklyScheduleDay(3)" id="btn-sch-day-3" class="day-select-btn" style="flex: 1; padding: 0.5rem; border: none; border-radius: 9px; font-size: 0.8rem; font-weight: 700; cursor: pointer; transition: all 0.2s; background: transparent; color: #4b5563;">Çar</button>
                        <button type="button" onclick="selectWeeklyScheduleDay(4)" id="btn-sch-day-4" class="day-select-btn" style="flex: 1; padding: 0.5rem; border: none; border-radius: 9px; font-size: 0.8rem; font-weight: 700; cursor: pointer; transition: all 0.2s; background: transparent; color: #4b5563;">Per</button>
                        <button type="button" onclick="selectWeeklyScheduleDay(5)" id="btn-sch-day-5" class="day-select-btn" style="flex: 1; padding: 0.5rem; border: none; border-radius: 9px; font-size: 0.8rem; font-weight: 700; cursor: pointer; transition: all 0.2s; background: transparent; color: #4b5563;">Cum</button>
                    </div>

                    @for (int dayNum = 1; dayNum <= 5; dayNum++)
                    {
                        var daySchedules = weeklySchedule.Where(s => s.DayOfWeek == dayNum).OrderBy(s => s.StartTime).ToList();
                        <div id="sch-day-container-@dayNum" class="schedule-day-panel" style="display: @(dayNum == 1 ? "block" : "none");">
                            @if (!daySchedules.Any())
                            {
                                <p style="color: var(--text-secondary); text-align: center; padding: 1.5rem; font-size: 0.85rem; font-style: italic;">
                                    Bu gün için planlanmış bir etkinlik bulunmuyor.
                                </p>
                            }
                            else
                            {
                                <div class="timeline" style="margin-left: 0.5rem;">
                                    @foreach (var item in daySchedules)
                                    {
                                        var emoji = item.Type switch
                                        {
                                            2 => "🍔", // Lunch
                                            3 => "🌙", // Sleep / Dinlenme
                                            _ => "📚"  // General/Art/Music
                                        };
                                        <div class="timeline-item" style="gap: 1rem;">
                                            <div class="timeline-dot" style="font-size: 0.9rem; width: 28px; height: 28px;">
                                                @emoji
                                            </div>
                                            <div class="timeline-content">
                                                <div class="timeline-title" style="font-size: 0.9rem; font-weight: 700;">
                                                    <span>@item.StartTime.ToString(@"hh\:mm") - @item.EndTime.ToString(@"hh\:mm")</span>
                                                </div>
                                                <div style="font-weight: 600; font-size: 0.85rem; color: var(--text-primary); margin-top: 0.15rem;">
                                                    @item.Title
                                                </div>
                                                @if (!string.IsNullOrEmpty(item.Description))
                                                {
                                                    <div class="timeline-desc" style="font-size: 0.78rem; color: var(--text-secondary); margin-top: 0.15rem; font-style: italic;">
                                                        @item.Description
                                                    </div>
                                                }
                                            </div>
                                        </div>
                                    }
                                </div>
                            }
                        </div>
                    }
                </div>
            </div>

            <!-- TAB 3: BÜLTENLER BÖLÜMÜ -->
            <div id="tab-parent-newsletters" class="modern-tab-content">
                <div class="glass-card" style="padding: 2rem;">
                    <h2 style="font-size: 1.4rem; font-weight: 700; color: var(--text-primary); margin-bottom: 1.5rem; display: flex; align-items: center; gap: 0.5rem;">
                        📰 Haftalık Sınıf Bültenleri
                    </h2>

                    @if (newsletters.Count == 0)
                    {
                        <p style="color: var(--text-secondary); text-align: center; padding: 2rem; font-size: 0.9rem; font-style: italic;">
                            Henüz yayınlanmış bir bülten bulunmuyor.
                        </p>
                    }
                    else
                    {
                        <div style="display: flex; flex-direction: column; gap: 1rem;">
                            @foreach (var newsletter in newsletters)
                            {
                                <div id="newsletter-pdf-@newsletter.Id" style="border: 1px solid var(--border-color); border-radius: 12px; padding: 1.2rem; background: rgba(255,255,255,0.6); box-shadow: 0 4px 15px rgba(0,0,0,0.02); position: relative;">
                                    <div data-html2canvas-ignore style="position: absolute; right: 1rem; top: 1rem;">
                                        <button onclick="downloadNewsletterPdf('@newsletter.Id', '@newsletter.Title')" class="btn-secondary" style="padding: 0.3rem 0.6rem; font-size: 0.8rem; display: flex; align-items: center; gap: 0.3rem;" title="Bülteni PDF Olarak İndir">
                                            <span>📥</span> PDF İndir
                                        </button>
                                    </div>
                                    <h3 style="font-size: 1.15rem; margin-bottom: 0.5rem; color: var(--accent-blue); padding-right: 6rem;">@newsletter.Title</h3>
                                    <p style="font-size: 0.9rem; color: var(--text-secondary); margin-bottom: 1rem; line-height: 1.5;">@newsletter.Content</p>
                                    @if (!string.IsNullOrEmpty(newsletter.ImageUrl))
                                    {
                                        <a href="@newsletter.ImageUrl" target="_blank" style="display: inline-block; margin-bottom: 1rem; font-size: 0.85rem; color: var(--accent-purple); font-weight: 600;">🔗 İlgili Görsele/Dosyaya Git</a>
                                    }
                                    <div style="font-size: 0.75rem; color: var(--text-muted); text-align: right;">
                                        Yayınlanma: @newsletter.PublishedAt?.ToString("dd MMMM yyyy")
                                    </div>
                                </div>
                            }
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

<!-- VELİ İLAÇ TALEP MODALI -->
<div id="parentMedicationModal" class="simple-modal">
    <div class="glass-card simple-modal-content" style="max-width: 450px;">
        <div class="section-card-header" style="margin-bottom: 1.5rem; display: flex; justify-content: space-between; align-items: center;">
            <h2>İlaç Talebi Ekle</h2>
            <button onclick="closeParentMedicationModal()" style="background:none; border:none; color:var(--text-muted); font-size:1.5rem; cursor:pointer;">&times;</button>
        </div>
        <div>
            <p style="font-weight: 700; color: var(--accent-blue); margin-bottom: 1rem;">@ViewBag.StudentName</p>
            <div class="form-group">
                <label for="pMedName">İlaç Adı</label>
                <input type="text" id="pMedName" class="form-control" placeholder="Örn: Calpol, Parol Şurup" required />
            </div>
            <div class="form-group">
                <label for="pMedDosage">Dozaj / Miktar</label>
                <input type="text" id="pMedDosage" class="form-control" placeholder="Örn: 1 ölçek, 5 ml, 1 tablet" required />
            </div>
            <div class="form-group">
                <label for="pMedTime">Veriliş Saati</label>
                <input type="time" id="pMedTime" class="form-control" value="08:00" required />
            </div>
            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem;">
                <div class="form-group">
                    <label for="pMedStartDate">Başlangıç Tarihi</label>
                    <input type="date" id="pMedStartDate" class="form-control" required />
                </div>
                <div class="form-group">
                    <label for="pMedEndDate">Bitiş Tarihi</label>
                    <input type="date" id="pMedEndDate" class="form-control" required />
                </div>
            </div>
            <div class="form-group">
                <label for="pMedNote">Öğretmene İletilecek Not (Opsiyonel)</label>
                <textarea id="pMedNote" class="form-control" style="height: 80px; resize: none;" placeholder="Örn: Yemeklerden sonra tok karna verilecek..."></textarea>
            </div>
            <div style="display: flex; gap: 1rem; margin-top: 2rem;">
                <button type="button" onclick="closeParentMedicationModal()" class="btn-secondary" style="flex: 1;">İptal</button>
                <button type="button" onclick="saveParentMedication()" class="btn-primary" style="flex: 1; margin-top: 0;">Talebi Gönder</button>
            </div>
        </div>
    </div>
</div>

<!-- Chart.js initialization script -->
@if (totalPlannedCalories > 0)
{
    <script>
        document.addEventListener("DOMContentLoaded", function() {
            var ctx = document.getElementById('nutritionChart').getContext('2d');
            
            // Veri serisini alalim
            var plannedCal = @totalPlannedCalories;
            var consumedCal = @((int)Math.Round(totalConsumedCalories));
            var plannedProt = @totalPlannedProtein.ToString("0.0", System.Globalization.CultureInfo.InvariantCulture);
            var consumedProt = @totalConsumedProtein.ToString("0.0", System.Globalization.CultureInfo.InvariantCulture);
            var plannedCarb = @totalPlannedCarbs.ToString("0.0", System.Globalization.CultureInfo.InvariantCulture);
            var consumedCarb = @totalConsumedCarbs.ToString("0.0", System.Globalization.CultureInfo.InvariantCulture);

            var myChart = new Chart(ctx, {
                type: 'bar',
                data: {
                    labels: ['Enerji (kcal / 10)', 'Protein (gram)', 'Karbonhidrat (gram)'],
                    datasets: [
                        {
                            label: 'Planlanan Hedef',
                            data: [plannedCal / 10, plannedProt, plannedCarb],
                            backgroundColor: 'rgba(71, 85, 105, 0.15)',
                            borderColor: 'rgba(71, 85, 105, 0.4)',
                            borderWidth: 1.5,
                            borderRadius: 6
                        },
                        {
                            label: 'Tüketilen Miktar',
                            data: [consumedCal / 10, consumedProt, consumedCarb],
                            backgroundColor: [
                                'rgba(2, 132, 199, 0.75)', // Sky blue for energy
                                'rgba(16, 185, 129, 0.75)', // Green for protein
                                'rgba(245, 158, 11, 0.75)'  // Amber for carbs
                            ],
                            borderColor: [
                                '#0284c7',
                                '#10b981',
                                '#f59e0b'
                            ],
                            borderWidth: 1.5,
                            borderRadius: 6
                        }
                    ]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    scales: {
                        y: {
                            beginAtZero: true,
                            grid: {
                                color: 'rgba(220, 205, 190, 0.25)'
                            },
                            ticks: {
                                font: {
                                    family: 'Inter',
                                    size: 11
                                }
                            }
                        },
                        x: {
                            grid: {
                                display: false
                            },
                            ticks: {
                                font: {
                                    family: 'Outfit',
                                    weight: 'bold',
                                    size: 12
                                }
                            }
                        }
                    },
                    plugins: {
                        legend: {
                            labels: {
                                font: {
                                    family: 'Outfit',
                                    size: 12
                                }
                            }
                        },
                        tooltip: {
                            callbacks: {
                                label: function(context) {
                                    var label = context.dataset.label || '';
                                    if (label) {
                                        label += ': ';
                                    }
                                    if (context.dataIndex === 0) {
                                        label += Math.round(context.raw * 10) + ' kcal';
                                    } else {
                                        label += context.raw.toFixed(1) + ' g';
                                    }
                                    return label;
                                }
                            }
                        }
                    }
                }
            });
        });
    </script>
}

<script>
        function downloadNewsletterPdf(id, title) {
            var element = document.getElementById('newsletter-pdf-' + id);
            var opt = {
                margin:       [15, 15, 15, 15],
                filename:     title + '.pdf',
                image:        { type: 'jpeg', quality: 0.98 },
                html2canvas:  { scale: 2, useCORS: true },
                jsPDF:        { unit: 'mm', format: 'a4', orientation: 'portrait' }
            };
            
            // html2pdf will ignore elements with data-html2canvas-ignore
            html2pdf().set(opt).from(element).save();
        }

        function switchParentTab(tabId) {
            // Deactivate all parent tab content
            document.querySelectorAll('#tab-parent-activities, #tab-parent-weekly, #tab-parent-newsletters').forEach(content => {
                content.classList.remove('active');
            });
            
            // Deactivate all parent tab buttons
            document.querySelectorAll('#btn-parent-activities, #btn-parent-weekly, #btn-parent-newsletters').forEach(btn => {
                btn.classList.remove('active');
            });
            
            // Activate target
            document.getElementById(tabId).classList.add('active');
            
            // Activate button
            let btnId = '';
            if (tabId === 'tab-parent-activities') btnId = 'btn-parent-activities';
            else if (tabId === 'tab-parent-weekly') btnId = 'btn-parent-weekly';
            else if (tabId === 'tab-parent-newsletters') btnId = 'btn-parent-newsletters';
            
            document.getElementById(btnId).classList.add('active');
        }

        function selectWeeklyScheduleDay(dayNum) {
            // Hide all day panels
            document.querySelectorAll('.schedule-day-panel').forEach(panel => {
                panel.style.display = 'none';
            });
            
            // Deactivate all day buttons
            document.querySelectorAll('.day-select-btn').forEach(btn => {
                btn.style.background = 'transparent';
                btn.style.color = '#4b5563';
                btn.classList.remove('active-day');
            });
            
            // Show selected day panel
            document.getElementById('sch-day-container-' + dayNum).style.display = 'block';
            
            // Activate selected day button
            const btn = document.getElementById('btn-sch-day-' + dayNum);
            btn.style.background = '#1e293b';
            btn.style.color = 'white';
            btn.classList.add('active-day');
        }

        function changeChildDate(val) {
            const urlParams = new URLSearchParams(window.location.search);
            urlParams.set('date', val);
            window.location.search = urlParams.toString();
        }

        function openParentMedicationModal() {
            document.getElementById('pMedName').value = '';
            document.getElementById('pMedDosage').value = '';
            document.getElementById('pMedTime').value = '08:00';
            document.getElementById('pMedNote').value = '';
            
            // Set default dates to selected page date or today
            const selectedDate = document.getElementById('child-date-picker').value;
            document.getElementById('pMedStartDate').value = selectedDate;
            document.getElementById('pMedEndDate').value = selectedDate;
            
            document.getElementById('parentMedicationModal').style.display = 'flex';
        }

        function closeParentMedicationModal() {
            document.getElementById('parentMedicationModal').style.display = 'none';
        }

        async function saveParentMedication() {
            const name = document.getElementById('pMedName').value.trim();
            const dosage = document.getElementById('pMedDosage').value.trim();
            const time = document.getElementById('pMedTime').value;
            const note = document.getElementById('pMedNote').value.trim();
            const startDateStr = document.getElementById('pMedStartDate').value;
            const endDateStr = document.getElementById('pMedEndDate').value;

            if (!name || !dosage || !time || !startDateStr || !endDateStr) {
                alert("Lütfen tüm alanları doldurunuz.");
                return;
            }

            const start = new Date(startDateStr);
            const end = new Date(endDateStr);

            if (end < start) {
                alert("Bitiş tarihi başlangıç tarihinden önce olamaz.");
                return;
            }

            // Loop and submit for each date
            let currentDate = new Date(start);
            let promises = [];

            while (currentDate <= end) {
                const dateStr = currentDate.toISOString().split('T')[0];
                
                promises.push(
                    fetch('/Parent/AddMedicationRecord', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({
                            studentId: '@ViewBag.StudentId',
                            medicineName: name,
                            dosage: dosage,
                            administrationTime: time,
                            taken: false,
                            note: note || null,
                            date: dateStr
                        })
                    }).then(res => res.json())
                );

                currentDate.setDate(currentDate.getDate() + 1);
            }

            try {
                const results = await Promise.all(promises);
                const failed = results.filter(r => !r.success);
                
                if (failed.length > 0) {
                    alert(`${failed.length} ilaç kaydı oluşturulurken hata meydana geldi: ` + failed[0].message);
                } else {
                    window.location.reload();
                }
            } catch (err) {
                console.error(err);
                alert("İlaç talepleri gönderilirken iletişim hatası oluştu.");
            }
        }

        async function deleteParentMedication(id) {
            if (!confirm("Bu ilaç talebini iptal etmek / silmek istediğinize emin misiniz?")) return;

            try {
                const res = await fetch(`/Parent/DeleteMedicationRecord?id=${id}`, {
                    method: 'POST'
                });
                const data = await res.json();
                if (data.success) {
                    window.location.reload();
                } else {
                    alert("İlaç talebi silinirken hata oluştu: " + data.message);
                }
            } catch (err) {
                console.error(err);
                alert("İletişim hatası.");
            }
        }
    </script>
