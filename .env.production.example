# SchoolInfo Production Environment Variables
# Bu dosya sunucuda ~/ebaro/.env olarak saklanmalıdır.
# GIT'E COMMIT ETMEYİN - .gitignore'a ekli olduğundan emin olun.

# === PostgreSQL ===
POSTGRES_PASSWORD=12345678A

# === API Secrets ===
ConnectionStrings__DefaultConnection=Host=schoolinfo-db;Database=SchoolInfoDb;Username=postgres;Password=12345678A
Jwt__Key=VerySecretAndLongSecurityKeyThatMeetsTheMinimumRequirementOf256Bits_1234567890
AgentFramework__ApiKey=YOUR_GEMINI_API_KEY

# === ASP.NET Core ===
ASPNETCORE_ENVIRONMENT=Production
